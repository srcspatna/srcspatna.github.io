---
import GlobalLayout from '../../layouts/Layout.astro';
import { buildPageTitle } from '../../config/site';

const {
  title = 'School Page',
  description,
} = Astro.props as {
  title?: string;
  description?: string;
};
---

<GlobalLayout
  title={buildPageTitle(title)}
  bannerEyebrow="School Page"
  bannerTitle={title}
  bannerText={description || 'Reference information and evergreen school content displayed in a polished page layout.'}
  bannerTone="emerald"
>
  <article class="content-shell mx-auto max-w-4xl overflow-hidden rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
    <slot />
  </article>
</GlobalLayout>

<style>
  .content-shell :global(h1),
  .content-shell :global(h2),
  .content-shell :global(h3),
  .content-shell :global(h4) {
    color: rgb(15 23 42);
    font-family: 'Merriweather', serif;
    line-height: 1.2;
    margin-top: 1.75rem;
    margin-bottom: 0.9rem;
  }

  .content-shell :global(h1) {
    font-size: 2.25rem;
    margin-top: 0;
  }

  .content-shell :global(h2) {
    font-size: 1.8rem;
  }

  .content-shell :global(h3) {
    font-size: 1.35rem;
  }

  .content-shell :global(p),
  .content-shell :global(li) {
    color: rgb(51 65 85);
    font-size: 1rem;
    line-height: 1.9;
  }

  .content-shell :global(p),
  .content-shell :global(ul),
  .content-shell :global(ol),
  .content-shell :global(table) {
    margin-bottom: 1.25rem;
  }

  .content-shell :global(ul),
  .content-shell :global(ol) {
    padding-left: 1.4rem;
  }

  .content-shell :global(a) {
    color: rgb(5 150 105);
    font-weight: 600;
    text-decoration: none;
  }

  .content-shell :global(a:hover) {
    text-decoration: underline;
  }

  .content-shell :global(table) {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgb(226 232 240);
  }

  .content-shell :global(th),
  .content-shell :global(td) {
    border: 1px solid rgb(226 232 240);
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
  }

  .content-shell :global(th) {
    background: rgb(248 250 252);
    color: rgb(15 23 42);
  }

  .content-shell :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 4px solid rgb(16 185 129);
    padding-left: 1rem;
    color: rgb(71 85 105);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .content-shell {
      padding: 1.5rem;
    }

    .content-shell :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>