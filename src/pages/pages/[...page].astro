---
import { getCollection, render } from 'astro:content';
import GlobalLayout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentCard from '../../components/ContentCard.astro';
import { buildPageTitle } from '../../config/site';

const prettyLabel = (segment: string) => segment
  .replace(/-/g, ' ')
  .replace(/\b\w/g, (char) => char.toUpperCase());

const formatDate = (value?: string) => {
  if (!value) {
    return undefined;
  }

  const parsedDate = new Date(value);

  if (Number.isNaN(parsedDate.valueOf())) {
    return undefined;
  }

  return parsedDate.toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
};

export async function getStaticPaths() {
  const entries = await getCollection('pages');
  const allPaths = new Set<string>();
  const toStaticPathSlug = (value: string) => value.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');

  for (const entry of entries) {
    const slug = toStaticPathSlug(entry.id);

    allPaths.add(slug);

    const segments = slug.split('/').filter(Boolean);

    for (let index = 1; index < segments.length; index += 1) {
      allPaths.add(segments.slice(0, index).join('/'));
    }
  }

  return [...allPaths].map((path) => ({
    params: { page: path },
  }));
}

const currentPath = Astro.params.page || '';
const entries = await getCollection('pages');
const toSlug = (value: string) => value.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
const entry = entries.find((item) => toSlug(item.id) === currentPath);
const categoryPrefix = `${currentPath}/`;
const categoryItems = entries
  .map((item) => {
    const slug = toSlug(item.id);

    return {
      slug,
      data: item.data,
    };
  })
  .filter((item) => item.slug.startsWith(categoryPrefix))
  .filter((item) => {
    const relativePath = item.slug.slice(categoryPrefix.length);

    return relativePath.length > 0 && !relativePath.includes('/');
  })
  .map((item) => ({
    href: `/pages/${item.slug}/`,
    title: item.data.title?.trim() || prettyLabel(item.slug.split('/').pop() || 'Page'),
    description: item.data.description?.trim() || 'Open this category page to view complete details.',
    dateLabel: formatDate(item.data.date),
    tag: item.data.section?.trim() || 'Page',
  }));

const isCategoryPage = categoryItems.length > 0;

if (!entry && !isCategoryPage) {
  throw new Error(`Page content not found for slug: ${currentPath}`);
}

const pageTitle = entry?.data.title?.trim() || prettyLabel(currentPath.split('/').filter(Boolean).pop() || 'School Page');
const pageDescription = entry?.data.description?.trim();
const sectionDescription = pageDescription || `Browse all pages in the ${pageTitle} category.`;
const crumbSegments = currentPath.split('/').filter(Boolean);
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Pages', href: '/pages' },
  ...crumbSegments.map((segment, index) => {
    const href = `/pages/${crumbSegments.slice(0, index + 1).join('/')}`;
    const isLast = index === crumbSegments.length - 1;

    return {
      label: isLast ? pageTitle : prettyLabel(segment),
      href: isLast ? undefined : href,
    };
  }),
];

let Content;

if (entry && !isCategoryPage) {
  ({ Content } = await render(entry));
}
---

<GlobalLayout
  title={buildPageTitle(pageTitle)}
  bannerEyebrow={isCategoryPage ? 'Category' : 'School Page'}
  bannerTitle={pageTitle}
  bannerText={isCategoryPage ? sectionDescription : (pageDescription || 'Reference information and evergreen school content displayed in a polished page layout.')}
  bannerTone="emerald"
>
  <Breadcrumbs items={breadcrumbItems} />

  {isCategoryPage ? (
    <section class="space-y-8">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {categoryItems.map((item) => (
          <ContentCard item={item} tone="emerald" />
        ))}
      </div>
    </section>
  ) : (
    <article class="content-shell mx-auto max-w-4xl overflow-hidden rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
      {Content && <Content />}
    </article>
  )}
</GlobalLayout>

<style>
  .content-shell :global(h1),
  .content-shell :global(h2),
  .content-shell :global(h3),
  .content-shell :global(h4) {
    color: rgb(15 23 42);
    font-family: 'Merriweather', serif;
    line-height: 1.2;
    margin-top: 1.75rem;
    margin-bottom: 0.9rem;
  }

  .content-shell :global(h1) {
    font-size: 2.25rem;
    margin-top: 0;
  }

  .content-shell :global(h2) {
    font-size: 1.8rem;
  }

  .content-shell :global(h3) {
    font-size: 1.35rem;
  }

  .content-shell :global(p),
  .content-shell :global(li) {
    color: rgb(51 65 85);
    font-size: 1rem;
    line-height: 1.9;
  }

  .content-shell :global(p),
  .content-shell :global(ul),
  .content-shell :global(ol),
  .content-shell :global(table) {
    margin-bottom: 1.25rem;
  }

  .content-shell :global(ul),
  .content-shell :global(ol) {
    padding-left: 1.4rem;
  }

  .content-shell :global(a) {
    color: rgb(5 150 105);
    font-weight: 600;
    text-decoration: none;
  }

  .content-shell :global(a:hover) {
    text-decoration: underline;
  }

  .content-shell :global(table) {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgb(226 232 240);
  }

  .content-shell :global(th),
  .content-shell :global(td) {
    border: 1px solid rgb(226 232 240);
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
  }

  .content-shell :global(th) {
    background: rgb(248 250 252);
    color: rgb(15 23 42);
  }

  .content-shell :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 4px solid rgb(16 185 129);
    padding-left: 1rem;
    color: rgb(71 85 105);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .content-shell {
      padding: 1.5rem;
    }

    .content-shell :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>