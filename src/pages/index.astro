---
import { getCollection } from 'astro:content';
import ContentCard from '../components/ContentCard.astro';
import HomeShowcase from '../components/HomeShowcase.astro';
import Layout from '../layouts/Layout.astro';
import { buildPageTitle, siteConfig } from '../config/site';

type ListingItem = {
	href: string;
	title: string;
	description: string;
	dateLabel?: string;
	tag: string;
	sortValue?: number;
};

type ShowcaseFeatureItem = {
	href: string;
	title: string;
	description: string;
	tag: string;
	dateLabel?: string;
};

const prettyLabel = (segment: string) => segment
	.replace(/-/g, ' ')
	.replace(/\b\w/g, (char) => char.toUpperCase());

const formatDate = (value?: string) => {
	if (!value) {
		return undefined;
	}

	const parsedDate = new Date(value);

	if (Number.isNaN(parsedDate.valueOf())) {
		return undefined;
	}

	return parsedDate.toLocaleDateString('en-US', {
		day: 'numeric',
		month: 'short',
		year: 'numeric',
	});
};

const extractDateString = (value?: string) => value?.match(/\d{4}-\d{2}-\d{2}/)?.[0];

const pageEntries = await getCollection('pages');
const postEntries = await getCollection('posts');
const marqueeEntries = await getCollection('marquee_items');
const showcaseEntries = await getCollection('showcase');

const marqueeItems = marqueeEntries
	.sort((left, right) => left.id.localeCompare(right.id))
	.map((entry) => entry.data.description.trim())
	.filter(Boolean);

const showcaseSlides = showcaseEntries
	.sort((left, right) => left.id.localeCompare(right.id))
	.map((entry) => ({
		eyebrow: entry.data.eyebrow,
		title: entry.data.title,
		description: entry.data.description,
		ctaLabel: entry.data.ctaLabel,
		ctaHref: entry.data.ctaHref,
		secondaryLabel: entry.data.secondaryLabel,
		secondaryHref: entry.data.secondaryHref,
		statLabel: entry.data.statLabel,
		statValue: entry.data.statValue,
		accent: entry.data.accent,
	}));

const categoryMap = new Map<string, number>();

for (const entry of pageEntries) {
	const slug = entry.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
	const [topLevel] = slug.split('/');

	if (!topLevel || topLevel === slug) {
		continue;
	}

	categoryMap.set(topLevel, (categoryMap.get(topLevel) || 0) + 1);
}

const categoryCards: ListingItem[] = [...categoryMap.entries()]
	.sort(([left], [right]) => left.localeCompare(right))
	.map(([category, count]) => ({
		href: `/pages/${category}/`,
		title: prettyLabel(category),
		description: `Browse ${count} pages in ${prettyLabel(category)}.`,
		tag: 'Category',
	}));

const recentUpdates: ListingItem[] = pageEntries
	.map((entry) => {
		const slug = entry.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
		const dateString = entry.data.date || extractDateString(slug);
		const parsedTime = dateString ? new Date(dateString).valueOf() : 0;

		return {
			href: `/pages/${slug}/`,
			title: entry.data.title?.trim() || prettyLabel(slug.split('/').pop() || 'School Page'),
			description: entry.data.description?.trim() || 'Open to read complete details.',
			dateLabel: formatDate(dateString),
			tag: entry.data.section?.trim() || 'Update',
			sortValue: Number.isNaN(parsedTime) ? 0 : parsedTime,
		};
	})
	.sort((left, right) => (right.sortValue || 0) - (left.sortValue || 0))
	.slice(0, 6);

const featuredPostItems: ShowcaseFeatureItem[] = [
	...postEntries.map((entry) => {
		const slug = entry.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
		const dateString = entry.data.date || extractDateString(slug);
		const parsedTime = dateString ? new Date(dateString).valueOf() : 0;

		return {
			href: `/posts/${slug}/`,
			title: entry.data.title?.trim() || prettyLabel(slug.split('/').pop() || 'School Post'),
			description: entry.data.description?.trim() || 'Open the full post for details and updates.',
			dateLabel: formatDate(dateString),
			tag: entry.data.section?.trim() || 'Post',
			sortValue: Number.isNaN(parsedTime) ? 0 : parsedTime,
		};
	}),
	...recentUpdates.map((item) => ({
		href: item.href,
		title: item.title,
		description: item.description,
		dateLabel: item.dateLabel,
		tag: item.tag,
		sortValue: item.sortValue || 0,
	})),
]
	.sort((left, right) => ((right as ListingItem).sortValue || 0) - ((left as ListingItem).sortValue || 0))
	.slice(0, 5)
	.map(({ href, title, description, dateLabel, tag }) => ({ href, title, description, dateLabel, tag }));

const totalPages = pageEntries.length;
const totalCategories = categoryCards.length;
const totalPosts = postEntries.length;
---

<Layout
	title={buildPageTitle('Home')}
	bannerEyebrow="Welcome"
	bannerTitle="Shri Ram Centenary School, Patna"
	bannerText="Explore categories, circulars, admissions, facilities, and important school updates from one organized landing page."
	bannerTone="amber"
>
	<Fragment slot="afterHeader">
		<HomeShowcase
			activitySlides={siteConfig.home.activitySlides}
			featuredItems={featuredPostItems}
			marqueeItems={marqueeItems}
			slides={showcaseSlides}
		/>
	</Fragment>

	<section class="space-y-10">
		<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
			<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
				<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">School Pages</p>
				<p class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">{totalPages}</p>
			</div>
			<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
				<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Categories</p>
				<p class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">{totalCategories}</p>
			</div>
			<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
				<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Posts</p>
				<p class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">{totalPosts}</p>
			</div>
			<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
				<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Quick Access</p>
				<div class="mt-3 flex flex-wrap gap-2">
					<a href="/pages" class="rounded-full bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white">Pages</a>
					<a href="/pages/circular/" class="rounded-full bg-amber-500 px-3 py-1.5 text-xs font-semibold text-white">Circulars</a>
					<a href="/pages/admission/" class="rounded-full bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white">Admissions</a>
				</div>
			</div>
		</div>

		<section class="space-y-4">
			<div class="flex items-end justify-between gap-3">
				<h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Browse Categories</h2>
				<a href="/pages" class="text-sm font-semibold text-slate-600 hover:text-slate-900">View all pages</a>
			</div>
			<div class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:grid-cols-3">
				{categoryCards.slice(0, 6).map((item) => (
					<ContentCard item={item} tone="emerald" />
				))}
			</div>
		</section>

		<section class="space-y-4">
			<div class="flex items-end justify-between gap-3">
				<h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Recent Updates</h2>
				<a href="/pages" class="text-sm font-semibold text-slate-600 hover:text-slate-900">Open directory</a>
			</div>
			<div class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:grid-cols-3">
				{recentUpdates.map((item) => (
					<ContentCard item={item} tone="blue" />
				))}
			</div>
		</section>
	</section>
</Layout>
