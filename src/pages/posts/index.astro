---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/PostsLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildPageTitle } from '../../config/site';

type ListingItem = {
  href: string;
  title: string;
  description: string;
  dateLabel?: string;
  tag: string;
  sortValue: number;
};

const PAGE_SIZE = 6;

const formatDate = (value?: string) => {
  if (!value) {
    return undefined;
  }

  const parsedDate = new Date(value);

  if (Number.isNaN(parsedDate.valueOf())) {
    return undefined;
  }

  return parsedDate.toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
};

const extractDateString = (value?: string) => value?.match(/\d{4}-\d{2}-\d{2}/)?.[0];

const entries = await getCollection('posts');

const postItems: ListingItem[] = entries
  .map((entry) => {
    const slug = entry.slug || entry.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
    const dateString = entry.data.date || extractDateString(slug);
    const parsedTime = dateString ? new Date(dateString).valueOf() : 0;

    return {
      href: `/posts/${slug}/`,
      title: entry.data.title?.trim() || 'School Post',
      description: entry.data.description?.trim() || 'Read the full school post for complete details and important context.',
      dateLabel: formatDate(dateString),
      tag: entry.data.section?.trim() || 'Post',
      sortValue: Number.isNaN(parsedTime) ? 0 : parsedTime,
    };
  })
  .sort((left, right) => right.sortValue - left.sortValue);

const totalItems = postItems.length;
const lastPage = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
const data = postItems.slice(0, PAGE_SIZE);
const pageTitle = buildPageTitle('School Posts');
---

<Layout title={pageTitle}>
  <section class="space-y-8">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Posts' }]} />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:grid-cols-3">
      {data.map((item) => (
        <ContentCard item={item} tone="blue" />
      ))}
    </div>

    {lastPage > 1 && (
      <nav class="flex flex-wrap items-center justify-center gap-3 border-t border-slate-200 pt-8">
        <span class="inline-flex rounded-full border border-slate-200 px-5 py-2 text-sm font-semibold text-slate-300">
          Previous
        </span>

        <span class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">
          Page 1 of {lastPage}
        </span>

        <a href="/posts/page/2" class="inline-flex rounded-full border border-slate-300 px-5 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-950 hover:text-slate-950">
          Next
        </a>
      </nav>
    )}
  </section>
</Layout>
