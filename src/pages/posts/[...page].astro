---
import { getCollection, render } from 'astro:content';
import GlobalLayout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildPageTitle } from '../../config/site';

export async function getStaticPaths() {
  const entries = await getCollection('posts');

  return entries.map((entry) => ({
    params: { page: entry.slug || entry.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '') },
  }));
}

const currentPath = Astro.params.page || '';
const entries = await getCollection('posts');
const entry = entries.find((item) => (item.slug || item.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')) === currentPath);

if (!entry) {
  throw new Error(`Post content not found for slug: ${currentPath}`);
}

const { Content } = await render(entry);
const pageTitle = entry.data.title?.trim() || 'School Post';
const pageDescription = entry.data.description?.trim();
const crumbSegments = currentPath.split('/').filter(Boolean);
const prettyLabel = (segment: string) => segment
  .replace(/-/g, ' ')
  .replace(/\b\w/g, (char) => char.toUpperCase());
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Posts', href: '/posts' },
  ...crumbSegments.map((segment, index) => {
    const href = `/posts/${crumbSegments.slice(0, index + 1).join('/')}`;
    const isLast = index === crumbSegments.length - 1;

    return {
      label: isLast ? pageTitle : prettyLabel(segment),
      href: isLast ? undefined : href,
    };
  }),
];
---

<GlobalLayout
  title={buildPageTitle(pageTitle)}
  bannerEyebrow="School Post"
  bannerTitle={pageTitle}
  bannerText={pageDescription || 'Full post details, notices, and school communication presented in a focused reading layout.'}
  bannerTone="blue"
>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="content-shell mx-auto max-w-4xl overflow-hidden rounded-4xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-10">
    <Content />
  </article>
</GlobalLayout>

<style>
  .content-shell :global(h1),
  .content-shell :global(h2),
  .content-shell :global(h3),
  .content-shell :global(h4) {
    color: rgb(15 23 42);
    font-family: 'Merriweather', serif;
    line-height: 1.2;
    margin-top: 1.75rem;
    margin-bottom: 0.9rem;
  }

  .content-shell :global(h1) {
    font-size: 2.25rem;
    margin-top: 0;
  }

  .content-shell :global(h2) {
    font-size: 1.8rem;
  }

  .content-shell :global(h3) {
    font-size: 1.35rem;
  }

  .content-shell :global(p),
  .content-shell :global(li) {
    color: rgb(51 65 85);
    font-size: 1rem;
    line-height: 1.9;
  }

  .content-shell :global(p),
  .content-shell :global(ul),
  .content-shell :global(ol),
  .content-shell :global(table) {
    margin-bottom: 1.25rem;
  }

  .content-shell :global(ul),
  .content-shell :global(ol) {
    padding-left: 1.4rem;
  }

  .content-shell :global(a) {
    color: rgb(3 105 161);
    font-weight: 600;
    text-decoration: none;
  }

  .content-shell :global(a:hover) {
    text-decoration: underline;
  }

  .content-shell :global(table) {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgb(226 232 240);
  }

  .content-shell :global(th),
  .content-shell :global(td) {
    border: 1px solid rgb(226 232 240);
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
  }

  .content-shell :global(th) {
    background: rgb(248 250 252);
    color: rgb(15 23 42);
  }

  .content-shell :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 4px solid rgb(14 165 233);
    padding-left: 1rem;
    color: rgb(71 85 105);
    font-style: italic;
  }

  :global(html.dark) .content-shell :global(h1),
  :global(html.dark) .content-shell :global(h2),
  :global(html.dark) .content-shell :global(h3),
  :global(html.dark) .content-shell :global(h4) {
    color: rgb(241 245 249);
  }

  :global(html.dark) .content-shell :global(p),
  :global(html.dark) .content-shell :global(li) {
    color: rgb(203 213 225);
  }

  :global(html.dark) .content-shell :global(a) {
    color: rgb(125 211 252);
  }

  :global(html.dark) .content-shell :global(table) {
    border-color: rgb(51 65 85);
  }

  :global(html.dark) .content-shell :global(th),
  :global(html.dark) .content-shell :global(td) {
    border-color: rgb(51 65 85);
  }

  :global(html.dark) .content-shell :global(th) {
    background: rgb(30 41 59);
    color: rgb(241 245 249);
  }

  :global(html.dark) .content-shell :global(td) {
    color: rgb(203 213 225);
  }

  :global(html.dark) .content-shell :global(blockquote) {
    color: rgb(148 163 184);
  }

  @media (max-width: 640px) {
    .content-shell {
      padding: 1.5rem;
    }

    .content-shell :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>