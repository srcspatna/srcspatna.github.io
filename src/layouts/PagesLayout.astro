---
import Layout from './Layout.astro';

const {
  title = 'School Pages | Greenwood School',
  bannerTitle = 'School Pages',
  bannerText = 'Explore evergreen school information, reference content, and important notices arranged in a page directory that is easy to scan.',
} = Astro.props as {
  title?: string;
  bannerTitle?: string;
  bannerText?: string;
};
---

<Layout
  title={title}
  bannerEyebrow="Information Directory"
  bannerTitle={bannerTitle}
  bannerText={bannerText}
  bannerTone="emerald"
>
  <slot />
</Layout>