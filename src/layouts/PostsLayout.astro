---
import Layout from './Layout.astro';
import { buildPageTitle } from '../config/site';

const {
  title = buildPageTitle('School Posts'),
  bannerTitle = 'School Posts',
  bannerText = 'Browse school announcements, notices, opportunities, and updates in a clean archive built for parents, students, and staff.',
} = Astro.props as {
  title?: string;
  bannerTitle?: string;
  bannerText?: string;
};
---

<Layout
  title={title}
  bannerEyebrow="Updates Archive"
  bannerTitle={bannerTitle}
  bannerText={bannerText}
  bannerTone="blue"
>
  <slot />
</Layout>