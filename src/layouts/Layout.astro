---
import '../styles/global.css';
import { resolveSiteUrl, siteConfig } from '../config/site';

type BannerTone = 'blue' | 'emerald' | 'amber';

const {
    title = siteConfig.seo.defaultTitle,
    description = siteConfig.seo.defaultDescription,
  bannerEyebrow,
  bannerTitle,
  bannerText,
  bannerTone = 'blue',
  mainClass = 'mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8',
} = Astro.props as {
  title?: string;
    description?: string;
  bannerEyebrow?: string;
  bannerTitle?: string;
  bannerText?: string;
  bannerTone?: BannerTone;
  mainClass?: string;
};

const navLinks = siteConfig.navigation;
const searchEnabled = siteConfig.features.search;
const pathname = Astro.url.pathname;
const bannerThemes: Record<BannerTone, { shell: string; badge: string; glow: string }> = {
  blue: {
    shell: 'from-slate-950 via-blue-900 to-sky-600',
    badge: 'bg-white/12 text-sky-100 ring-1 ring-white/15',
    glow: 'bg-sky-300/20',
  },
  emerald: {
    shell: 'from-slate-950 via-emerald-900 to-teal-500',
    badge: 'bg-white/12 text-emerald-100 ring-1 ring-white/15',
    glow: 'bg-emerald-300/20',
  },
  amber: {
    shell: 'from-slate-950 via-amber-900 to-orange-500',
    badge: 'bg-white/12 text-amber-100 ring-1 ring-white/15',
    glow: 'bg-amber-300/20',
  },
};

const activeLinkClass = (href: string) => {
  if (href === '/') {
    return pathname === '/';
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};

const selectedTheme = bannerThemes[bannerTone];
const hasFeature = Astro.slots.has('feature');
const canonicalUrl = resolveSiteUrl(pathname);
const previewImageUrl = resolveSiteUrl(siteConfig.branding.previewImage.src);
---

<!DOCTYPE html>
<html lang={siteConfig.site.locale}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={siteConfig.seo.robots} />
    <meta name="theme-color" content={siteConfig.site.themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type={siteConfig.branding.favicon.type} href={siteConfig.branding.favicon.src} />
    <link rel="apple-touch-icon" href={siteConfig.branding.favicon.src} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteConfig.site.locale} />
    <meta property="og:site_name" content={siteConfig.site.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={previewImageUrl} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Merriweather:wght@700&display=swap" rel="stylesheet" />
    
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 antialiased" data-search-enabled={searchEnabled ? 'true' : 'false'}>
    <div class="flex min-h-screen flex-col">
        <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur">
            <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="flex min-w-0 items-center gap-3 text-slate-950">
                    <span class="flex h-11 w-11 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white shadow-lg shadow-slate-900/10 ring-1 ring-slate-200 sm:h-12 sm:w-12">
                        <img src={siteConfig.branding.logo.src} alt={siteConfig.branding.logo.alt} class="h-full w-full object-cover" width={siteConfig.branding.logo.width} height={siteConfig.branding.logo.height} loading="eager" decoding="async" />
                    </span>
                    <span class="min-w-0">
                        <span class="block truncate text-[0.65rem] font-semibold uppercase tracking-[0.26em] text-sky-700 sm:text-xs sm:tracking-[0.32em]">{siteConfig.branding.eyebrow}</span>
                        <span class="block truncate text-lg font-extrabold tracking-tight sm:text-xl">{siteConfig.site.name}</span>
                    </span>
                </a>

                <div class="flex items-center gap-2 md:hidden">
                    {searchEnabled && (
                        <button
                            type="button"
                            data-search-open
                            class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                            aria-label="Open search"
                        >
                            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="11" cy="11" r="7" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 20l-3.5-3.5" />
                            </svg>
                        </button>
                    )}

                    <button
                        id="mobile-nav-toggle"
                        type="button"
                        class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                        aria-expanded="false"
                        aria-controls="mobile-nav-menu"
                        aria-label="Toggle navigation"
                    >
                        <svg id="mobile-nav-open-icon" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        <svg id="mobile-nav-close-icon" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
                        </svg>
                    </button>
                </div>

                <div class="hidden items-center gap-2 sm:gap-3 md:flex">
                    <nav class="flex items-center gap-2 sm:gap-3" aria-label="Primary navigation">
                        {navLinks.map((link) => (
                            <a
                                href={link.href}
                                class:list={[
                                    'rounded-full px-4 py-2 text-sm font-semibold transition-colors duration-200',
                                    activeLinkClass(link.href)
                                        ? 'bg-slate-950 text-white'
                                        : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                                ]}
                            >
                                {link.label}
                            </a>
                        ))}
                    </nav>

                    {searchEnabled && (
                        <button
                            type="button"
                            data-search-open
                            class="inline-flex items-center justify-center rounded-full border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                            aria-label="Open search"
                        >
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="11" cy="11" r="7" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 20l-3.5-3.5" />
                            </svg>
                        </button>
                    )}
                </div>
            </div>

            <nav id="mobile-nav-menu" class="hidden border-t border-slate-200 bg-white/95 px-4 pb-4 pt-3 md:hidden" aria-label="Mobile navigation">
                <div class="mx-auto grid w-full max-w-7xl gap-2">
                    {navLinks.map((link) => (
                        <a
                            href={link.href}
                            class:list={[
                                'rounded-xl px-4 py-3 text-sm font-semibold transition-colors duration-200',
                                activeLinkClass(link.href)
                                    ? 'bg-slate-950 text-white'
                                    : 'text-slate-700 hover:bg-slate-100 hover:text-slate-950',
                            ]}
                        >
                            {link.label}
                        </a>
                    ))}
                </div>
            </nav>
        </header>

        {searchEnabled && (
            <div id="search-overlay" class="fixed inset-0 z-90 hidden bg-slate-950/80 p-4 backdrop-blur-sm sm:p-8" aria-hidden="true">
                <div class="mx-auto flex h-full w-full max-w-5xl flex-col rounded-4xl border border-white/15 bg-slate-900/90 p-4 shadow-2xl shadow-slate-950/60 sm:p-8">
                    <div class="mb-4 flex items-center justify-between gap-3 sm:mb-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-300">Search School Content</p>
                        <button
                            type="button"
                            data-search-close
                            class="inline-flex items-center justify-center rounded-full border border-white/20 p-2 text-white transition hover:bg-white/10"
                            aria-label="Close search"
                        >
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
                            </svg>
                        </button>
                    </div>

                    <div class="rounded-3xl border border-white/15 bg-white/95 p-3 shadow-lg shadow-slate-950/20 sm:p-4">
                        <label for="site-search-input" class="sr-only">Search pages and posts</label>
                        <input
                            id="site-search-input"
                            type="search"
                            placeholder="Search pages, posts, admissions, circulars..."
                            class="w-full border-0 bg-transparent text-base font-medium text-slate-900 placeholder:text-slate-500 focus:outline-none sm:text-lg"
                            autocomplete="off"
                        />
                    </div>

                    <div id="site-search-status" class="mt-4 text-sm text-slate-300 sm:mt-5">Type at least 2 letters to search.</div>
                    <div id="site-search-results" class="mt-4 flex-1 overflow-y-auto pr-1 sm:mt-6"></div>
                </div>
            </div>
        )}

        {bannerTitle && (
            <section class="bg-slate-950 px-4 py-6 sm:px-6 lg:px-8">
                <div class={`mx-auto w-full max-w-7xl overflow-hidden rounded-4xl bg-linear-to-br ${selectedTheme.shell}`}>
                    <div class="relative isolate overflow-hidden px-6 py-10 sm:px-10 sm:py-14 lg:px-14">
                        <div class={`absolute -right-12 top-0 h-48 w-48 rounded-full blur-3xl ${selectedTheme.glow}`}></div>
                        <div class="absolute inset-y-0 right-0 hidden w-1/3 bg-white/5 md:block"></div>
                        <div class="relative z-10 max-w-3xl">
                            {bannerEyebrow && (
                                <span class={`inline-flex rounded-full px-4 py-1 text-xs font-semibold uppercase tracking-[0.28em] ${selectedTheme.badge}`}>
                                    {bannerEyebrow}
                                </span>
                            )}
                            <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
                                {bannerTitle}
                            </h1>
                            {bannerText && (
                                <p class="mt-4 max-w-2xl text-base leading-8 text-slate-100/90 sm:text-lg">
                                    {bannerText}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            </section>
        )}

        {hasFeature && (
            <section class="px-4 py-6 sm:px-6 lg:px-8">
                <div class="mx-auto w-full max-w-7xl">
                    <slot name="feature" />
                </div>
            </section>
        )}

        <main class={`flex-1 ${mainClass}`}>
            <slot />
        </main>

        <footer class="border-t border-slate-200 bg-white">
            <div class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-4 py-8 text-sm text-slate-500 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                <p>© {new Date().getFullYear()} {siteConfig.site.name}. {siteConfig.footer.primaryText}</p>
                <p>{siteConfig.footer.secondaryText}</p>
            </div>
        </footer>
    </div>

    <script>
        const toggleButton = document.getElementById('mobile-nav-toggle');
        const mobileMenu = document.getElementById('mobile-nav-menu');
        const openIcon = document.getElementById('mobile-nav-open-icon');
        const closeIcon = document.getElementById('mobile-nav-close-icon');
        const mobileLinks = mobileMenu?.querySelectorAll('a');
        const searchEnabled = document.body.dataset.searchEnabled === 'true';
        const searchOverlay = searchEnabled ? document.getElementById('search-overlay') : null;
        const searchOpenButtons = searchEnabled ? document.querySelectorAll('[data-search-open]') : [];
        const searchCloseButtons = searchEnabled ? document.querySelectorAll('[data-search-close]') : [];
        const searchInput = searchEnabled ? document.getElementById('site-search-input') : null;
        const searchStatus = searchEnabled ? document.getElementById('site-search-status') : null;
        const searchResults = searchEnabled ? document.getElementById('site-search-results') : null;

        let searchIndex = [];
        let searchLoaded = false;

        const closeMobileMenu = () => {
            mobileMenu?.classList.add('hidden');
            openIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
            toggleButton?.setAttribute('aria-expanded', 'false');
        };

        const escapeHtml = (value) => value
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const renderResults = (query) => {
            if (!searchEnabled || !searchResults || !searchStatus) {
                return;
            }

            const trimmed = query.trim();

            if (trimmed.length < 2) {
                searchStatus.textContent = 'Type at least 2 letters to search.';
                searchResults.innerHTML = '';
                return;
            }

            const normalized = trimmed.toLowerCase();
            const matches = searchIndex
                .filter((item) => {
                    const content = `${item.title} ${item.description} ${item.section} ${item.url}`.toLowerCase();

                    return content.includes(normalized);
                })
                .slice(0, 20);

            searchStatus.textContent = `${matches.length} result${matches.length === 1 ? '' : 's'} found.`;

            if (matches.length === 0) {
                searchResults.innerHTML = '<p class="rounded-2xl border border-white/15 bg-white/5 p-4 text-sm text-slate-300">No matching content found.</p>';
                return;
            }

            searchResults.innerHTML = matches
                .map((item) => `
                    <a href="${item.url}" class="mb-3 block rounded-2xl border border-white/15 bg-white/5 p-4 transition hover:border-sky-300/60 hover:bg-white/10">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">${escapeHtml(item.section || item.type)}</p>
                        <p class="mt-2 text-lg font-bold tracking-tight text-white">${escapeHtml(item.title)}</p>
                        <p class="mt-2 text-sm leading-6 text-slate-300">${escapeHtml(item.description || 'Open this result to view details.')}</p>
                        <p class="mt-3 text-xs text-slate-400">${escapeHtml(item.url)}</p>
                    </a>
                `)
                .join('');
        };

        const loadSearchIndex = async () => {
            if (!searchEnabled || searchLoaded) {
                return;
            }

            try {
                const response = await fetch('/search-index.json');

                if (!response.ok) {
                    throw new Error('Failed to load search index');
                }

                searchIndex = await response.json();
                searchLoaded = true;
            } catch {
                if (searchStatus) {
                    searchStatus.textContent = 'Search is unavailable right now.';
                }
            }
        };

        const openSearch = async () => {
            if (!searchEnabled || !searchOverlay) {
                return;
            }

            closeMobileMenu();
            searchOverlay.classList.remove('hidden');
            searchOverlay.style.display = 'block';
            searchOverlay.setAttribute('aria-hidden', 'false');
            document.body.classList.add('overflow-hidden');

            await loadSearchIndex();

            setTimeout(() => {
                searchInput?.focus();
            }, 30);
        };

        const closeSearch = () => {
            if (!searchEnabled || !searchOverlay) {
                return;
            }

            searchOverlay.classList.add('hidden');
            searchOverlay.style.display = 'none';
            searchOverlay.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('overflow-hidden');
        };

        toggleButton?.addEventListener('click', () => {
            const isHidden = mobileMenu?.classList.toggle('hidden');
            const isOpen = isHidden === false;

            openIcon?.classList.toggle('hidden', isOpen);
            closeIcon?.classList.toggle('hidden', !isOpen);
            toggleButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        mobileLinks?.forEach((link) => {
            link.addEventListener('click', closeMobileMenu);
        });

        if (searchEnabled) {
            searchOpenButtons.forEach((button) => {
                button.addEventListener('click', openSearch);
            });

            searchCloseButtons.forEach((button) => {
                button.addEventListener('click', closeSearch);
            });

            // Delegated fallback so search still works even if nav markup changes.
            document.addEventListener('click', (event) => {
                const target = event.target;

                if (!(target instanceof Element)) {
                    return;
                }

                if (target.closest('[data-search-open]')) {
                    event.preventDefault();
                    openSearch();
                    return;
                }

                if (target.closest('[data-search-close]')) {
                    event.preventDefault();
                    closeSearch();
                }
            });

            searchOverlay?.addEventListener('click', (event) => {
                if (event.target === searchOverlay) {
                    closeSearch();
                }
            });

            searchInput?.addEventListener('input', (event) => {
                const target = event.target;
                const query = target && 'value' in target ? target.value : '';

                renderResults(query);
            });

            document.addEventListener('keydown', (event) => {
                const hasMetaKey = event.metaKey || event.ctrlKey;

                if (event.key === 'Escape') {
                    closeSearch();
                }

                if (hasMetaKey && event.key.toLowerCase() === 'k') {
                    event.preventDefault();
                    openSearch();
                }
            });
        }

        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) {
                closeMobileMenu();
            }
        });
    </script>
</body>
</html>