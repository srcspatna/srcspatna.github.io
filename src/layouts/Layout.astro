---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { resolveSiteUrl, siteConfig } from '../config/site';

type BannerTone = 'blue' | 'emerald' | 'amber';

const {
    title = siteConfig.seo.defaultTitle,
    description = siteConfig.seo.defaultDescription,
  bannerEyebrow,
  bannerTitle,
  bannerText,
  bannerTone = 'blue',
  mainClass = 'mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8',
} = Astro.props as {
  title?: string;
    description?: string;
  bannerEyebrow?: string;
  bannerTitle?: string;
  bannerText?: string;
  bannerTone?: BannerTone;
  mainClass?: string;
};

const activeSocialLinks = siteConfig.socialLinks.filter((link) => link.href.trim().length > 0);
const searchEnabled = siteConfig.features.search;
const themeToggleEnabled = siteConfig.features.themeToggle;
const showBrandName = siteConfig.appearance.showBrandName;
const showSiteName = siteConfig.appearance.showSiteName;
const showEyebrow = siteConfig.appearance.showEyebrow;
const showWatermark = siteConfig.appearance.showWatermark;
const brandLogoImage = siteConfig.appearance.brandLogoImage === 'wordmark' 
  ? siteConfig.branding.wordmark 
  : siteConfig.branding.logo;
const availableThemes = [
    siteConfig.appearance.enableLightTheme ? 'light' : null,
    siteConfig.appearance.enableDarkTheme ? 'dark' : null,
    siteConfig.appearance.enableSystemTheme ? 'system' : null,
].filter((mode): mode is 'light' | 'dark' | 'system' => mode !== null);
const defaultTheme = availableThemes.includes(siteConfig.appearance.defaultTheme)
    ? siteConfig.appearance.defaultTheme
    : availableThemes[0] ?? 'system';
const topBarEnabled = siteConfig.features.topBar;
const topBarSocialIconsEnabled = siteConfig.features.topBarSocialIcons;
const topBarContactInfoEnabled = siteConfig.features.topBarContactInfo;
const topBarShowOnSmallScreen = siteConfig.features.topBarShowOnSmallScreen;
const topBarShowOnLargeScreen = siteConfig.features.topBarShowOnLargeScreen;
const topBarContactInfoShowOnSmallScreen = siteConfig.features.topBarContactInfoShowOnSmallScreen;
const topBarContactInfoShowOnLargeScreen = siteConfig.features.topBarContactInfoShowOnLargeScreen;
const topBarSocialIconsShowOnSmallScreen = siteConfig.features.topBarSocialIconsShowOnSmallScreen;
const topBarSocialIconsShowOnLargeScreen = siteConfig.features.topBarSocialIconsShowOnLargeScreen;
const navbarStickyEnabled = siteConfig.features.navbarSticky;
const pathname = Astro.url.pathname;
const trackingConfig = siteConfig.tracking;
const gtmId = trackingConfig.gtm.containerId.trim();
const gtmDataLayerName = trackingConfig.gtm.dataLayerName.trim() || 'dataLayer';
const gtmEnabled = trackingConfig.gtm.enabled && gtmId.length > 0;
const ga4Id = trackingConfig.ga4.measurementId.trim();
const ga4Enabled = trackingConfig.ga4.enabled && !trackingConfig.ga4.viaTagManager && ga4Id.length > 0;
const customTrackingTags = trackingConfig.customTags.filter((tag) => tag.enabled && tag.html.trim().length > 0);
const headTrackingTags = customTrackingTags.filter((tag) => tag.placement === 'head');
const bodyStartTrackingTags = customTrackingTags.filter((tag) => tag.placement === 'body-start');
const bodyEndTrackingTags = customTrackingTags.filter((tag) => tag.placement === 'body-end');
const gtmInlineScript = gtmEnabled
    ? `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','${gtmDataLayerName}','${gtmId}');`
    : '';
const ga4BootstrapScript = ga4Enabled
    ? `window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${ga4Id}', { send_page_view: ${trackingConfig.ga4.sendPageView ? 'true' : 'false'} });`
    : '';
const gtmNoScriptSrc = `https://www.googletagmanager.com/ns.html?id=${gtmId}`;
const ga4ScriptSrc = `https://www.googletagmanager.com/gtag/js?id=${ga4Id}`;
const bannerThemes: Record<BannerTone, { shell: string; badge: string; glow: string }> = {
  blue: {
    shell: 'from-slate-950 via-blue-900 to-sky-600',
    badge: 'bg-white/12 text-sky-100 ring-1 ring-white/15',
    glow: 'bg-sky-300/20',
  },
  emerald: {
    shell: 'from-slate-950 via-emerald-900 to-teal-500',
    badge: 'bg-white/12 text-emerald-100 ring-1 ring-white/15',
    glow: 'bg-emerald-300/20',
  },
  amber: {
    shell: 'from-slate-950 via-amber-900 to-orange-500',
    badge: 'bg-white/12 text-amber-100 ring-1 ring-white/15',
    glow: 'bg-amber-300/20',
  },
};

type NavigationNode = {
    href?: string;
    label?: string;
    right_icon?: string;
    items?: NavigationNode[];
};

type HeaderNavItem = {
    href: string;
    label: string;
    rightIcon?: string;
    children: HeaderNavItem[];
};

type FooterNavLink = {
    href: string;
    label: string;
    rightIcon?: string;
};

const normalizeNavigation = (items: NavigationNode[] = []): HeaderNavItem[] => {
    const links: HeaderNavItem[] = [];

    for (const item of items) {
        const children = normalizeNavigation(Array.isArray(item.items) ? item.items : []);

        if (typeof item.href === 'string' && typeof item.label === 'string') {
            links.push({
                href: item.href,
                label: item.label,
                rightIcon: typeof item.right_icon === 'string' ? item.right_icon : undefined,
                children,
            });
        } else if (children.length > 0) {
            // Allow container nodes with only nested `items` in JSON.
            links.push(...children);
        }
    }

    return links;
};

const escapeHtml = (value: string) => value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');

const renderDesktopMenu = (items: HeaderNavItem[], depth = 0): string => items.map((item) => {
    const hasChildren = item.children.length > 0;
    const activeClass = activeLinkClass(item.href)
        ? 'bg-slate-950 text-white'
        : 'text-slate-700 hover:bg-slate-100 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-700/70 dark:hover:text-white';
    const itemClasses = depth === 0
        ? `inline-flex items-center gap-1 rounded-full px-4 py-2 text-sm font-semibold transition-colors duration-200 ${activeClass}`
        : 'inline-flex w-full items-center justify-between gap-2 whitespace-nowrap rounded-xl px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-700/70 dark:hover:text-white';
    const caret = hasChildren
        ? '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" /></svg>'
        : '';
    const rightIcon = item.rightIcon === 'external-link'
        ? '<svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7" /><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9" /></svg>'
        : '';
    const submenuClass = depth === 0 ? 'nav-submenu nav-submenu-root' : 'nav-submenu nav-submenu-flyout';

    return `<li class="nav-menu-item">
        <a href="${escapeHtml(item.href)}" class="${itemClasses}">${escapeHtml(item.label)}${rightIcon}${caret}</a>
        ${hasChildren ? `<ul class="${submenuClass}">${renderDesktopMenu(item.children, depth + 1)}</ul>` : ''}
    </li>`;
}).join('');

const renderMobileMenu = (items: HeaderNavItem[], depth = 0): string => items.map((item) => {
    const hasChildren = item.children.length > 0;
    const activeClass = activeLinkClass(item.href)
        ? 'bg-slate-950 text-white'
        : 'text-slate-700 hover:bg-slate-100 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-700/70 dark:hover:text-white';
    const marginClass = depth > 0 ? 'ml-4 mt-1 border-l border-slate-200 pl-2' : '';
    const rightIcon = item.rightIcon === 'external-link'
        ? '<svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7" /><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9" /></svg>'
        : '';

    return `<div class="${marginClass}">
        <a href="${escapeHtml(item.href)}" class="inline-flex w-full items-center gap-1.5 rounded-xl px-4 py-3 text-sm font-semibold transition-colors duration-200 ${activeClass}">${escapeHtml(item.label)}${rightIcon}</a>
        ${hasChildren ? renderMobileMenu(item.children, depth + 1) : ''}
    </div>`;
}).join('');

const activeLinkClass = (href: string) => {
  if (href === '/') {
    return pathname === '/';
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};

const selectedTheme = bannerThemes[bannerTone];
const hasAfterHeader = Astro.slots.has('afterHeader');
const hasFeature = Astro.slots.has('feature');
const canonicalUrl = resolveSiteUrl(pathname);
const previewImageUrl = resolveSiteUrl(siteConfig.branding.previewImage.src);
const currentYear = new Date().getFullYear();
const navigationEntries = await getCollection('navigation');
const navFromContent = normalizeNavigation(navigationEntries[0]?.data.header_navigation || []);
const navLinks: HeaderNavItem[] = navFromContent.length > 0
    ? navFromContent
    : siteConfig.navigation.map((item) => ({ ...item, rightIcon: undefined, children: [] }));
const topbarSocialFromContent = (navigationEntries[0]?.data.topbar_social_links || [])
    .filter((item) => typeof item.href === 'string' && typeof item.label === 'string')
    .map((item) => ({ href: item.href as string, label: item.label as string }));
const topbarSocialLinks = topbarSocialFromContent.length > 0 ? topbarSocialFromContent : activeSocialLinks;
const topbarNavigationFromContent = (navigationEntries[0]?.data.topbar_navigation_links || [])
    .filter((item) => typeof item.label === 'string')
    .map((item) => ({
        href: typeof item.href === 'string' ? item.href.replace(/^email:/, 'mailto:') : undefined,
        label: item.label as string,
        leftIcon: typeof item.left_icon === 'string' ? item.left_icon : undefined,
        rightIcon: typeof item.right_icon === 'string' ? item.right_icon : undefined,
    }));
const topbarInfoLinks = topbarNavigationFromContent.length > 0 ? topbarNavigationFromContent : [
    { href: undefined, label: siteConfig.contact.address, leftIcon: 'map-pin' },
    { href: `tel:${siteConfig.contact.mobile}`, label: siteConfig.contact.mobile, leftIcon: 'phone' },
    { href: `tel:${siteConfig.contact.phone}`, label: siteConfig.contact.phone, leftIcon: 'phone' },
    { href: `mailto:${siteConfig.contact.email}`, label: siteConfig.contact.email, leftIcon: 'mail' },
    { href: undefined, label: siteConfig.contact.officeTime, leftIcon: 'clock' },
];
const desktopMenuHtml = renderDesktopMenu(navLinks);
const mobileMenuHtml = renderMobileMenu(navLinks);
const footerNavigationFromContent = (navigationEntries[0]?.data.footer_navigation || [])
    .filter((item) => typeof item.href === 'string' && typeof item.label === 'string')
    .map((item) => ({
        href: item.href as string,
        label: item.label as string,
        rightIcon: typeof item.right_icon === 'string' ? item.right_icon : undefined,
    }));
const footerEntries = await getCollection('footer');
const footerData = footerEntries[0]?.data.footer;
const footerHeading = footerData?.label?.trim() || 'About Us';
const footerAboutText = (footerData?.description?.trim() || [footerData?.primaryText, footerData?.secondaryText].filter(Boolean).join(' '))
    || 'Thoughtful learning, clear communication, and modern school operations.';
const footerNavigationLinks: FooterNavLink[] = footerNavigationFromContent.length > 0 ? footerNavigationFromContent : [
    { href: '/pages/blog/', label: 'Our Blogs' },
    { href: '/pages/circular/', label: 'Circulars' },
    { href: '/pages/admission/contact-us/', label: 'Contact Us' },
    { href: '/pages/admission/fee-structure/pre-primary/', label: 'Fee-Structure - Pre-Primary' },
    { href: '/pages/admission/fee-structure/primary-to-secondary/', label: 'Fee-Structure - Primary to Secondary' },
    { href: '/pages/admission/fee-structure/senior-secondary/', label: 'Fee-Structure - Senior Secondary' },
];
const formattedMobile = siteConfig.contact.mobile.replace('+91', '+91 ');
const formattedPhone = siteConfig.contact.phone.replace('+91', '+91 ');
const footerContactFromContent = (navigationEntries[0]?.data.footer_contact_info || [])
    .filter((item) => typeof item.label === 'string')
    .map((item) => ({
        href: typeof item.href === 'string' ? item.href : undefined,
        label: item.label as string,
        leftIcon: typeof item.left_icon === 'string' ? item.left_icon : undefined,
        rightIcon: typeof item.right_icon === 'string' ? item.right_icon : undefined,
    }));
const footerContactInfo = footerContactFromContent.length > 0 ? footerContactFromContent : [
    { href: `mailto:${siteConfig.contact.email}`, label: siteConfig.contact.email, leftIcon: 'mail' },
    { href: `tel:${siteConfig.contact.phone}`, label: formattedPhone, leftIcon: 'phone' },
    { href: `tel:${siteConfig.contact.mobile}`, label: formattedMobile, leftIcon: 'phone' },
    { label: siteConfig.contact.address, leftIcon: 'map-pin' },
    { label: siteConfig.contact.officeTime, leftIcon: 'clock' },
];
const footerSocialFromContent = (footerData?.social_links || [])
    .filter((item) => typeof item?.href === 'string' && typeof item?.label === 'string')
    .map((item) => ({ href: item.href as string, label: item.label as string }));
const footerSocialLinks = footerSocialFromContent.length > 0
    ? footerSocialFromContent
    : [
        { label: 'Facebook', href: 'https://www.facebook.com/groups/astroid/' },
        { label: 'X', href: 'https://x.com/' },
        { label: 'Github', href: 'https://github.com/templaza/astroid-framework' },
        { label: 'LinkedIn', href: 'https://linkedin.com/' },
        { label: 'Dribbble', href: 'https://dribbble.com/templaza' },
    ];
---

<!DOCTYPE html>
<html lang={siteConfig.site.locale}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={siteConfig.seo.robots} />
    <meta name="theme-color" content={siteConfig.site.themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type={siteConfig.branding.favicon.type} href={siteConfig.branding.favicon.src} />
    <link rel="apple-touch-icon" href={siteConfig.branding.favicon.src} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteConfig.site.locale} />
    <meta property="og:site_name" content={siteConfig.site.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={previewImageUrl} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Merriweather:wght@700&display=swap" rel="stylesheet" />
    {gtmEnabled && <script is:inline set:html={gtmInlineScript}></script>}
    {ga4Enabled && <script async src={ga4ScriptSrc}></script>}
    {ga4Enabled && <script is:inline set:html={ga4BootstrapScript}></script>}
    {headTrackingTags.map((tag) => <Fragment set:html={tag.html} />)}
    <script is:inline define:vars={{ defaultTheme, availableThemes }}>
        (() => {
            const storageKey = 'site-theme';
            const doc = document.documentElement;
            const isThemeValue = (value) => value === 'light' || value === 'dark' || value === 'system';
            const validThemes = Array.isArray(availableThemes) && availableThemes.length > 0
                ? availableThemes.filter((value) => isThemeValue(value))
                : ['light', 'dark', 'system'];

            let savedTheme = null;

            try {
                const stored = localStorage.getItem(storageKey);
                savedTheme = isThemeValue(stored) && validThemes.includes(stored) ? stored : null;
            } catch {
                savedTheme = null;
            }

            const preference = savedTheme || defaultTheme;
            const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            const resolvedTheme = preference === 'system' ? systemTheme : preference;

            doc.classList.toggle('dark', resolvedTheme === 'dark');
            doc.dataset.theme = resolvedTheme;
            doc.dataset.themePreference = preference;
            doc.dataset.themeModes = JSON.stringify(validThemes);
        })();
    </script>
</head>
<body
    class="min-h-screen bg-slate-50 text-slate-900 antialiased"
    data-search-enabled={searchEnabled ? 'true' : 'false'}
    data-theme-default={defaultTheme}
    data-theme-modes={JSON.stringify(availableThemes)}
>
    {gtmEnabled && (
        <noscript>
            <iframe src={gtmNoScriptSrc} height="0" width="0" style="display:none;visibility:hidden"></iframe>
        </noscript>
    )}
    {bodyStartTrackingTags.map((tag) => <Fragment set:html={tag.html} />)}
    <div id="site-top" class="flex min-h-screen flex-col">
        {topBarEnabled && (
            <div class:list={[
                'border-b border-slate-800 bg-slate-950 text-slate-100',
                topBarShowOnSmallScreen ? '' : 'hidden',
                topBarShowOnLargeScreen ? 'lg:block' : 'lg:hidden',
            ]}>
                <div class="mx-auto flex w-full max-w-7xl flex-col gap-2 px-4 py-2 text-xs sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                    {topBarContactInfoEnabled && (
                        <div class:list={[
                            'flex flex-wrap items-center gap-x-4 gap-y-1 leading-relaxed text-slate-200/95',
                            topBarContactInfoShowOnSmallScreen ? '' : 'hidden',
                            topBarContactInfoShowOnLargeScreen ? 'lg:flex' : 'lg:hidden',
                        ]}>
                        {topbarInfoLinks.map((item) => (
                            item.href ? (
                                <a href={item.href} class="inline-flex items-center gap-1.5 transition hover:text-white">
                                    {item.leftIcon === 'map-pin' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                    )}
                                    {item.leftIcon === 'phone' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.15 11.8 19.79 19.79 0 01.08 3.18 2 2 0 012.06 1h3a2 2 0 012 1.72c.12.9.33 1.77.62 2.6a2 2 0 01-.45 2.11L6.1 8.59a16 16 0 006.31 6.31l1.16-1.16a2 2 0 012.11-.45c.83.29 1.7.5 2.6.62A2 2 0 0122 16.92z" />
                                        </svg>
                                    )}
                                    {item.leftIcon === 'mail' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v16H4z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M22 6l-10 7L2 6" />
                                        </svg>
                                    )}
                                    {item.leftIcon === 'clock' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <circle cx="12" cy="12" r="10" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
                                        </svg>
                                    )}
                                    {item.leftIcon === 'whatsapp' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path d="M20.52 3.48A11.93 11.93 0 0012.05 0C5.52 0 .2 5.3.2 11.82c0 2.08.54 4.11 1.57 5.9L0 24l6.47-1.7a11.8 11.8 0 005.58 1.42h.01c6.53 0 11.85-5.3 11.85-11.82 0-3.16-1.23-6.13-3.39-8.42zM12.06 21.7h-.01a9.8 9.8 0 01-4.98-1.36l-.36-.21-3.84 1.01 1.03-3.75-.23-.39a9.74 9.74 0 01-1.5-5.18C2.17 6.4 6.58 2 12.05 2c2.6 0 5.04 1.01 6.87 2.85a9.66 9.66 0 012.83 6.86c0 5.43-4.41 9.84-9.69 9.84zm5.37-7.32c-.29-.14-1.73-.85-2- .95-.27-.1-.47-.14-.67.14-.2.29-.77.95-.94 1.14-.17.19-.35.21-.64.07-.29-.14-1.24-.46-2.36-1.48-.87-.78-1.46-1.75-1.63-2.04-.17-.29-.02-.45.13-.59.13-.13.29-.35.43-.52.14-.17.19-.29.29-.48.1-.19.05-.36-.02-.5-.07-.14-.67-1.6-.92-2.2-.24-.58-.48-.5-.67-.5h-.57c-.19 0-.5.07-.77.36-.27.29-1.01.99-1.01 2.41 0 1.42 1.03 2.79 1.17 2.98.14.19 2.02 3.08 4.89 4.32.68.29 1.22.46 1.64.59.69.22 1.32.19 1.81.12.55-.08 1.73-.71 1.97-1.39.24-.69.24-1.28.17-1.4-.07-.12-.26-.19-.55-.33z" />
                                        </svg>
                                    )}
                                    <span>{item.label}</span>
                                    {'rightIcon' in item && item.rightIcon === 'external-link' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9" />
                                        </svg>
                                    )}
                                </a>
                            ) : (
                                <span class="inline-flex items-center gap-1.5 text-slate-300">
                                    {item.leftIcon === 'map-pin' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                    )}
                                    {item.leftIcon === 'phone' && (
                                        <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
