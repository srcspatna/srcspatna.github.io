---
import '../styles/global.css';
import { resolveSiteUrl, siteConfig } from '../config/site';

type BannerTone = 'blue' | 'emerald' | 'amber';

const {
    title = siteConfig.seo.defaultTitle,
    description = siteConfig.seo.defaultDescription,
  bannerEyebrow,
  bannerTitle,
  bannerText,
  bannerTone = 'blue',
  mainClass = 'mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8',
} = Astro.props as {
  title?: string;
    description?: string;
  bannerEyebrow?: string;
  bannerTitle?: string;
  bannerText?: string;
  bannerTone?: BannerTone;
  mainClass?: string;
};

const navLinks = siteConfig.navigation;
const activeSocialLinks = siteConfig.socialLinks.filter((link) => link.href.trim().length > 0);
const searchEnabled = siteConfig.features.search;
const themeToggleEnabled = siteConfig.features.themeToggle;
const availableThemes = [
    siteConfig.appearance.enableLightTheme ? 'light' : null,
    siteConfig.appearance.enableDarkTheme ? 'dark' : null,
    siteConfig.appearance.enableSystemTheme ? 'system' : null,
].filter((mode): mode is 'light' | 'dark' | 'system' => mode !== null);
const defaultTheme = availableThemes.includes(siteConfig.appearance.defaultTheme)
    ? siteConfig.appearance.defaultTheme
    : availableThemes[0] ?? 'system';
const topBarEnabled = siteConfig.features.topBar;
const topBarSocialIconsEnabled = siteConfig.features.topBarSocialIcons;
const topBarContactInfoEnabled = siteConfig.features.topBarContactInfo;
const topBarShowOnSmallScreen = siteConfig.features.topBarShowOnSmallScreen;
const topBarShowOnLargeScreen = siteConfig.features.topBarShowOnLargeScreen;
const topBarContactInfoShowOnSmallScreen = siteConfig.features.topBarContactInfoShowOnSmallScreen;
const topBarContactInfoShowOnLargeScreen = siteConfig.features.topBarContactInfoShowOnLargeScreen;
const topBarSocialIconsShowOnSmallScreen = siteConfig.features.topBarSocialIconsShowOnSmallScreen;
const topBarSocialIconsShowOnLargeScreen = siteConfig.features.topBarSocialIconsShowOnLargeScreen;
const navbarStickyEnabled = siteConfig.features.navbarSticky;
const pathname = Astro.url.pathname;
const bannerThemes: Record<BannerTone, { shell: string; badge: string; glow: string }> = {
  blue: {
    shell: 'from-slate-950 via-blue-900 to-sky-600',
    badge: 'bg-white/12 text-sky-100 ring-1 ring-white/15',
    glow: 'bg-sky-300/20',
  },
  emerald: {
    shell: 'from-slate-950 via-emerald-900 to-teal-500',
    badge: 'bg-white/12 text-emerald-100 ring-1 ring-white/15',
    glow: 'bg-emerald-300/20',
  },
  amber: {
    shell: 'from-slate-950 via-amber-900 to-orange-500',
    badge: 'bg-white/12 text-amber-100 ring-1 ring-white/15',
    glow: 'bg-amber-300/20',
  },
};

const activeLinkClass = (href: string) => {
  if (href === '/') {
    return pathname === '/';
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};

const selectedTheme = bannerThemes[bannerTone];
const hasFeature = Astro.slots.has('feature');
const canonicalUrl = resolveSiteUrl(pathname);
const previewImageUrl = resolveSiteUrl(siteConfig.branding.previewImage.src);
---

<!DOCTYPE html>
<html lang={siteConfig.site.locale}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={siteConfig.seo.robots} />
    <meta name="theme-color" content={siteConfig.site.themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type={siteConfig.branding.favicon.type} href={siteConfig.branding.favicon.src} />
    <link rel="apple-touch-icon" href={siteConfig.branding.favicon.src} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteConfig.site.locale} />
    <meta property="og:site_name" content={siteConfig.site.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={previewImageUrl} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Merriweather:wght@700&display=swap" rel="stylesheet" />
    <script is:inline define:vars={{ defaultTheme, availableThemes }}>
        (() => {
            const storageKey = 'site-theme';
            const doc = document.documentElement;
            const isThemeValue = (value) => value === 'light' || value === 'dark' || value === 'system';
            const validThemes = Array.isArray(availableThemes) && availableThemes.length > 0
                ? availableThemes.filter((value) => isThemeValue(value))
                : ['light', 'dark', 'system'];

            let savedTheme = null;

            try {
                const stored = localStorage.getItem(storageKey);
                savedTheme = isThemeValue(stored) && validThemes.includes(stored) ? stored : null;
            } catch {
                savedTheme = null;
            }

            const preference = savedTheme || defaultTheme;
            const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            const resolvedTheme = preference === 'system' ? systemTheme : preference;

            doc.classList.toggle('dark', resolvedTheme === 'dark');
            doc.dataset.theme = resolvedTheme;
            doc.dataset.themePreference = preference;
            doc.dataset.themeModes = JSON.stringify(validThemes);
        })();
    </script>
</head>
<body
    class="min-h-screen bg-slate-50 text-slate-900 antialiased"
    data-search-enabled={searchEnabled ? 'true' : 'false'}
    data-theme-default={defaultTheme}
    data-theme-modes={JSON.stringify(availableThemes)}
>
    <div class="flex min-h-screen flex-col">
        {topBarEnabled && (
            <div class:list={[
                'border-b border-slate-800 bg-slate-950 text-slate-100',
                topBarShowOnSmallScreen ? '' : 'hidden',
                topBarShowOnLargeScreen ? 'lg:block' : 'lg:hidden',
            ]}>
                <div class="mx-auto flex w-full max-w-7xl flex-col gap-2 px-4 py-2 text-xs sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                    {topBarContactInfoEnabled && (
                        <div class:list={[
                            'flex flex-wrap items-center gap-x-4 gap-y-1 leading-relaxed text-slate-200/95',
                            topBarContactInfoShowOnSmallScreen ? '' : 'hidden',
                            topBarContactInfoShowOnLargeScreen ? 'lg:flex' : 'lg:hidden',
                        ]}>
                        <span class="inline-flex items-center gap-1.5">
                            <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                            {siteConfig.contact.address}
                        </span>

                        <a href={`tel:${siteConfig.contact.mobile}`} class="inline-flex items-center gap-1.5 transition hover:text-white">
                            <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.15 11.8 19.79 19.79 0 01.08 3.18 2 2 0 012.06 1h3a2 2 0 012 1.72c.12.9.33 1.77.62 2.6a2 2 0 01-.45 2.11L6.1 8.59a16 16 0 006.31 6.31l1.16-1.16a2 2 0 012.11-.45c.83.29 1.7.5 2.6.62A2 2 0 0122 16.92z" />
                            </svg>
                            {siteConfig.contact.mobile}
                        </a>

                        <a href={`tel:${siteConfig.contact.phone}`} class="inline-flex items-center gap-1.5 transition hover:text-white">
                            <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.15 11.8 19.79 19.79 0 01.08 3.18 2 2 0 012.06 1h3a2 2 0 012 1.72c.12.9.33 1.77.62 2.6a2 2 0 01-.45 2.11L6.1 8.59a16 16 0 006.31 6.31l1.16-1.16a2 2 0 012.11-.45c.83.29 1.7.5 2.6.62A2 2 0 0122 16.92z" />
                            </svg>
                            {siteConfig.contact.phone}
                        </a>

                        <a href={`mailto:${siteConfig.contact.email}`} class="inline-flex items-center gap-1.5 transition hover:text-white">
                            <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v16H4z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M22 6l-10 7L2 6" />
                            </svg>
                            {siteConfig.contact.email}
                        </a>

                        <span class="inline-flex items-center gap-1.5 text-slate-300">
                            <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="12" cy="12" r="10" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
                            </svg>
                            {siteConfig.contact.officeTime}
                        </span>
                        </div>
                    )}

                    {topBarSocialIconsEnabled && activeSocialLinks.length > 0 && (
                        <div class:list={[
                            'flex items-center gap-2',
                            topBarSocialIconsShowOnSmallScreen ? '' : 'hidden',
                            topBarSocialIconsShowOnLargeScreen ? 'lg:flex' : 'lg:hidden',
                        ]}>
                            {activeSocialLinks.map((social) => (
                                <a
                                    href={social.href}
                                    target="_blank"
                                    rel="noreferrer"
                                    class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-slate-700 text-slate-200 transition hover:border-amber-300 hover:text-white"
                                    aria-label={social.label}
                                    title={social.label}
                                >
                                    {social.label === 'Facebook' && (
                                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path d="M13.5 8H16V5h-2.5A4.5 4.5 0 009 9.5V12H7v3h2v4h3v-4h2.5l.5-3H12V9.5c0-.9.6-1.5 1.5-1.5z" />
                                        </svg>
                                    )}
                                    {social.label === 'Instagram' && (
                                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
                                            <circle cx="12" cy="12" r="4" />
                                            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                                        </svg>
                                    )}
                                    {social.label === 'LinkedIn' && (
                                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.03-1.85-3.03-1.86 0-2.14 1.45-2.14 2.94v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.27 2.37 4.27 5.46v6.28zM5.32 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.1 20.45H3.54V9H7.1v11.45z" />
                                        </svg>
                                    )}
                                    {social.label === 'YouTube' && (
                                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path d="M22.54 6.42a2.78 2.78 0 00-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46A2.78 2.78 0 001.46 6.42 29.94 29.94 0 001 12a29.94 29.94 0 00.46 5.58 2.78 2.78 0 001.94 1.96C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-1.96A29.94 29.94 0 0023 12a29.94 29.94 0 00-.46-5.58zM10 15.5v-7l6 3.5-6 3.5z" />
                                        </svg>
                                    )}
                                </a>
                            ))}
                        </div>
                    )}
                </div>
            </div>
        )}

        <header class:list={[
            'z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur',
            navbarStickyEnabled ? 'sticky top-0' : 'relative',
        ]}>

            <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="flex min-w-0 items-center gap-3 text-slate-950">
                    <span class="flex h-11 w-11 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white shadow-lg shadow-slate-900/10 ring-1 ring-slate-200 sm:h-12 sm:w-12">
                        <img src={siteConfig.branding.logo.src} alt={siteConfig.branding.logo.alt} class="h-full w-full object-cover" width={siteConfig.branding.logo.width} height={siteConfig.branding.logo.height} loading="eager" decoding="async" />
                    </span>
                    <span class="min-w-0">
                        <span class="block truncate text-[0.65rem] font-semibold uppercase tracking-[0.26em] text-sky-700 sm:text-xs sm:tracking-[0.32em]">{siteConfig.branding.eyebrow}</span>
                        <span class="block truncate text-lg font-extrabold tracking-tight sm:text-xl">{siteConfig.site.name}</span>
                    </span>
                </a>

                <div class="flex items-center gap-2 md:hidden">
                    {searchEnabled && (
                        <button
                            type="button"
                            data-search-open
                            class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                            aria-label="Open search"
                        >
                            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="11" cy="11" r="7" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 20l-3.5-3.5" />
                            </svg>
                        </button>
                    )}

                    <button
                        id="mobile-nav-toggle"
                        type="button"
                        class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                        aria-expanded="false"
                        aria-controls="mobile-nav-menu"
                        aria-label="Toggle navigation"
                    >
                        <svg id="mobile-nav-open-icon" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        <svg id="mobile-nav-close-icon" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
                        </svg>
                    </button>
                </div>

                <div class="hidden items-center gap-2 sm:gap-3 md:flex">
                    <nav class="flex items-center gap-2 sm:gap-3" aria-label="Primary navigation">
                        {navLinks.map((link) => (
                            <a
                                href={link.href}
                                class:list={[
                                    'rounded-full px-4 py-2 text-sm font-semibold transition-colors duration-200',
                                    activeLinkClass(link.href)
                                        ? 'bg-slate-950 text-white'
                                        : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                                ]}
                            >
                                {link.label}
                            </a>
                        ))}
                    </nav>

                    {searchEnabled && (
                        <button
                            type="button"
                            data-search-open
                            class="inline-flex items-center justify-center rounded-full border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                            aria-label="Open search"
                        >
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="11" cy="11" r="7" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 20l-3.5-3.5" />
                            </svg>
                        </button>
                    )}

                    {themeToggleEnabled && (
                        <button
                            type="button"
                            data-theme-toggle
                            class="inline-flex items-center justify-center rounded-full border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100 hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
                            aria-label="Toggle theme"
                            title="Toggle light and dark mode"
                        >
                            <svg data-theme-icon="sun" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="12" cy="12" r="4" />
                                <path stroke-linecap="round" d="M12 2v2" />
                                <path stroke-linecap="round" d="M12 20v2" />
                                <path stroke-linecap="round" d="M4.93 4.93l1.41 1.41" />
                                <path stroke-linecap="round" d="M17.66 17.66l1.41 1.41" />
                                <path stroke-linecap="round" d="M2 12h2" />
                                <path stroke-linecap="round" d="M20 12h2" />
                                <path stroke-linecap="round" d="M4.93 19.07l1.41-1.41" />
                                <path stroke-linecap="round" d="M17.66 6.34l1.41-1.41" />
                            </svg>
                            <svg data-theme-icon="moon" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
                            </svg>
                            <svg data-theme-icon="system" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <rect x="3" y="4" width="18" height="12" rx="2" ry="2" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 20h8" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 16v4" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14 16v4" />
                            </svg>
                        </button>
                    )}
                </div>
            </div>

        </header>

        <nav id="mobile-nav-menu" class="fixed inset-x-0 bottom-0 z-70 hidden md:hidden" style="top: 76px;" aria-label="Mobile navigation" aria-hidden="true">
            <div id="mobile-nav-backdrop" class="absolute inset-0 bg-slate-950/60 backdrop-blur-sm"></div>
            <div id="mobile-nav-panel" class="absolute right-0 top-0 flex h-full w-full max-w-md translate-x-full flex-col overflow-hidden bg-white shadow-2xl transition-transform duration-300 ease-out">
                <div class="flex-1 overflow-y-auto p-4">
                    <div class="grid gap-2 pb-4">
                    {navLinks.map((link) => (
                        <a
                            href={link.href}
                            class:list={[
                                'rounded-xl px-4 py-3 text-sm font-semibold transition-colors duration-200',
                                activeLinkClass(link.href)
                                    ? 'bg-slate-950 text-white'
                                    : 'text-slate-700 hover:bg-slate-100 hover:text-slate-950',
                            ]}
                        >
                            {link.label}
                        </a>
                    ))}
                    </div>
                </div>

                <div class="border-t border-slate-200/90 bg-white/95 p-3 backdrop-blur">
                    <div class="grid grid-cols-3 gap-2">
                        {themeToggleEnabled && (
                            <button
                                type="button"
                                data-theme-toggle
                                class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100"
                                aria-label="Toggle theme"
                                title="Toggle theme"
                            >
                                <svg data-theme-icon="sun" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <circle cx="12" cy="12" r="4" />
                                    <path stroke-linecap="round" d="M12 2v2" />
                                    <path stroke-linecap="round" d="M12 20v2" />
                                    <path stroke-linecap="round" d="M4.93 4.93l1.41 1.41" />
                                    <path stroke-linecap="round" d="M17.66 17.66l1.41 1.41" />
                                    <path stroke-linecap="round" d="M2 12h2" />
                                    <path stroke-linecap="round" d="M20 12h2" />
                                    <path stroke-linecap="round" d="M4.93 19.07l1.41-1.41" />
                                    <path stroke-linecap="round" d="M17.66 6.34l1.41-1.41" />
                                </svg>
                                <svg data-theme-icon="moon" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
                                </svg>
                                <svg data-theme-icon="system" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <rect x="3" y="4" width="18" height="12" rx="2" ry="2" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 20h8" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 16v4" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 16v4" />
                                </svg>
                            </button>
                        )}

                        {searchEnabled && (
                            <button
                                type="button"
                                data-search-open
                                class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100"
                                aria-label="Open search"
                            >
                                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <circle cx="11" cy="11" r="7" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 20l-3.5-3.5" />
                                </svg>
                            </button>
                        )}

                        <button
                            type="button"
                            data-mobile-nav-close
                            class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-2 text-slate-700 transition hover:bg-slate-100"
                            aria-label="Close menu"
                        >
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </nav>

        {searchEnabled && (
            <div id="search-overlay" class="fixed inset-0 z-90 hidden bg-slate-950/80 p-4 backdrop-blur-sm sm:p-8" aria-hidden="true">
                <div class="mx-auto flex h-full w-full max-w-5xl flex-col rounded-4xl border border-white/15 bg-slate-900/90 p-4 shadow-2xl shadow-slate-950/60 sm:p-8">
                    <div class="mb-4 flex items-center justify-between gap-3 sm:mb-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-300">Search School Content</p>
                        <button
                            type="button"
                            data-search-close
                            class="inline-flex items-center justify-center rounded-full border border-white/20 p-2 text-white transition hover:bg-white/10"
                            aria-label="Close search"
                        >
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
                            </svg>
                        </button>
                    </div>

                    <div class="rounded-3xl border border-white/15 bg-white/95 p-3 shadow-lg shadow-slate-950/20 sm:p-4">
                        <label for="site-search-input" class="sr-only">Search pages and posts</label>
                        <input
                            id="site-search-input"
                            type="search"
                            placeholder="Search pages, posts, admissions, circulars..."
                            class="w-full border-0 bg-transparent text-base font-medium text-slate-900 placeholder:text-slate-500 focus:outline-none sm:text-lg"
                            autocomplete="off"
                        />
                    </div>

                    <div id="site-search-status" class="mt-4 text-sm text-slate-300 sm:mt-5">Type at least 2 letters to search.</div>
                    <div id="site-search-results" class="mt-4 flex-1 overflow-y-auto pr-1 sm:mt-6"></div>
                </div>
            </div>
        )}

        {bannerTitle && (
            <section class="bg-slate-950 px-4 py-6 sm:px-6 lg:px-8">
                <div class={`mx-auto w-full max-w-7xl overflow-hidden rounded-4xl bg-linear-to-br ${selectedTheme.shell}`}>
                    <div class="relative isolate overflow-hidden px-6 py-10 sm:px-10 sm:py-14 lg:px-14">
                        <div class={`absolute -right-12 top-0 h-48 w-48 rounded-full blur-3xl ${selectedTheme.glow}`}></div>
                        <div class="absolute inset-y-0 right-0 hidden w-1/3 bg-white/5 md:block"></div>
                        <div class="relative z-10 max-w-3xl">
                            {bannerEyebrow && (
                                <span class={`inline-flex rounded-full px-4 py-1 text-xs font-semibold uppercase tracking-[0.28em] ${selectedTheme.badge}`}>
                                    {bannerEyebrow}
                                </span>
                            )}
                            <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
                                {bannerTitle}
                            </h1>
                            {bannerText && (
                                <p class="mt-4 max-w-2xl text-base leading-8 text-slate-100/90 sm:text-lg">
                                    {bannerText}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            </section>
        )}

        {hasFeature && (
            <section class="px-4 py-6 sm:px-6 lg:px-8">
                <div class="mx-auto w-full max-w-7xl">
                    <slot name="feature" />
                </div>
            </section>
        )}

        <main class={`flex-1 ${mainClass}`}>
            <slot />
        </main>

        <footer class="border-t border-slate-200 bg-white">
            <div class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-4 py-8 text-sm text-slate-500 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                <p>© {new Date().getFullYear()} {siteConfig.site.name}. {siteConfig.footer.primaryText}</p>
                <p>{siteConfig.footer.secondaryText}</p>
            </div>
        </footer>
    </div>

    <script>
        // @ts-nocheck
        const toggleButton = document.getElementById('mobile-nav-toggle');
        const headerElement = document.querySelector('header');
        const mobileMenu = document.getElementById('mobile-nav-menu');
        const mobileNavBackdrop = document.getElementById('mobile-nav-backdrop');
        const mobileNavPanel = document.getElementById('mobile-nav-panel');
        const mobileMenuCloseButtons = document.querySelectorAll('[data-mobile-nav-close]');
        const openIcon = document.getElementById('mobile-nav-open-icon');
        const closeIcon = document.getElementById('mobile-nav-close-icon');
        const mobileLinks = mobileMenu?.querySelectorAll('a');
        const searchEnabled = document.body.dataset.searchEnabled === 'true';
        const themeToggles = document.querySelectorAll('[data-theme-toggle]');
        const rootElement = document.documentElement;
        const themeMetaTag = document.querySelector('meta[name="theme-color"]');
        const lightThemeColor = '#0f172a';
        const darkThemeColor = '#020617';
        const defaultTheme = document.body.dataset.themeDefault || 'system';
        const parsedThemeModes = (() => {
            try {
                const parsed = JSON.parse(document.body.dataset.themeModes || '[]');

                if (!Array.isArray(parsed)) {
                    return [];
                }

                return parsed.filter((value) => value === 'light' || value === 'dark' || value === 'system');
            } catch {
                return [];
            }
        })();
        const themeModes = parsedThemeModes.length > 0 ? parsedThemeModes : ['light', 'dark', 'system'];
        const searchOverlay = searchEnabled ? document.getElementById('search-overlay') : null;
        const searchOpenButtons = searchEnabled ? document.querySelectorAll('[data-search-open]') : [];
        const searchCloseButtons = searchEnabled ? document.querySelectorAll('[data-search-close]') : [];
        const searchInput = searchEnabled ? document.getElementById('site-search-input') : null;
        const searchStatus = searchEnabled ? document.getElementById('site-search-status') : null;
        const searchResults = searchEnabled ? document.getElementById('site-search-results') : null;

        let searchIndexJson = '[]';
        let searchLoaded = false;
        const storageKey = 'site-theme';

        const getSystemTheme = () => window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

        const getThemePreference = () => {
            const savedPreference = rootElement.dataset.themePreference;

            if ((savedPreference === 'light' || savedPreference === 'dark' || savedPreference === 'system') && themeModes.includes(savedPreference)) {
                return savedPreference;
            }

            return themeModes.includes(defaultTheme) ? defaultTheme : themeModes[0];
        };

        const resolveTheme = (preference = 'system') => preference === 'system' ? getSystemTheme() : preference;

        const updateThemeButtons = (resolvedTheme = 'light', preference = 'system') => {
            themeToggles.forEach((button) => {
                const sunIcon = button.querySelector('[data-theme-icon="sun"]');
                const moonIcon = button.querySelector('[data-theme-icon="moon"]');
                const systemIcon = button.querySelector('[data-theme-icon="system"]');
                const isSystem = preference === 'system';
                const isDark = preference === 'dark';
                const isLight = preference === 'light';

                sunIcon?.classList.toggle('hidden', !isLight);
                moonIcon?.classList.toggle('hidden', !isDark);
                systemIcon?.classList.toggle('hidden', !isSystem);

                const modeText = isSystem
                    ? `Device automatic (${resolvedTheme})`
                    : isDark
                        ? 'Dark'
                        : 'Light';

                button.setAttribute('aria-label', `Theme mode: ${modeText}`);
                button.setAttribute('title', `Theme mode: ${modeText}`);
            });
        };

        const applyTheme = (preference = 'system') => {
            const resolvedTheme = resolveTheme(preference);
            const isDark = resolvedTheme === 'dark';

            rootElement.classList.toggle('dark', isDark);
            rootElement.dataset.theme = resolvedTheme;
            rootElement.dataset.themePreference = preference;

            if (themeMetaTag instanceof HTMLMetaElement) {
                themeMetaTag.content = isDark ? darkThemeColor : lightThemeColor;
            }

            updateThemeButtons(resolvedTheme, preference);
        };

        const cycleTheme = () => {
            const currentPreference = getThemePreference();
            const currentIndex = themeModes.indexOf(currentPreference);
            const nextIndex = currentIndex === -1
                ? 0
                : (currentIndex + 1) % themeModes.length;
            const nextPreference = themeModes[nextIndex];

            applyTheme(nextPreference);

            try {
                localStorage.setItem(storageKey, nextPreference);
            } catch {
                // Ignore storage errors in private/incognito contexts.
            }
        };

        const updateMobileToggleIcon = (isOpen = false) => {
            openIcon?.classList.toggle('hidden', isOpen);
            closeIcon?.classList.toggle('hidden', !isOpen);
            toggleButton?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        };

        const getMobileMenuTopOffset = () => {
            if (!(headerElement instanceof HTMLElement)) {
                return 76;
            }

            const headerRect = headerElement.getBoundingClientRect();

            // When top bar is visible, header can be lower than viewport top.
            // Drawer should start below the currently visible header block.
            return Math.max(0, Math.round(headerRect.bottom));
        };

        const openMobileMenu = () => {
            if (!mobileMenu || !mobileNavPanel) {
                return;
            }

            mobileMenu.style.top = `${getMobileMenuTopOffset()}px`;

            mobileMenu.classList.remove('hidden');
            mobileMenu.setAttribute('aria-hidden', 'false');

            requestAnimationFrame(() => {
                mobileNavPanel.classList.remove('translate-x-full');
            });

            updateMobileToggleIcon(true);
            document.body.classList.add('overflow-hidden');
        };

        try {
            const storedTheme = localStorage.getItem(storageKey);

            if ((storedTheme === 'light' || storedTheme === 'dark' || storedTheme === 'system') && themeModes.includes(storedTheme)) {
                applyTheme(storedTheme);
            } else {
                applyTheme(getThemePreference());
            }
        } catch {
            applyTheme(getThemePreference());
        }

        const colorSchemeQuery = window.matchMedia('(prefers-color-scheme: dark)');
        colorSchemeQuery.addEventListener('change', () => {
            if (getThemePreference() === 'system') {
                applyTheme('system');
            }
        });

        themeToggles.forEach((button) => {
            button.addEventListener('click', cycleTheme);
        });

        const closeMobileMenu = () => {
            if (!mobileMenu || !mobileNavPanel) {
                return;
            }

            mobileNavPanel.classList.add('translate-x-full');
            mobileMenu.setAttribute('aria-hidden', 'true');

            setTimeout(() => {
                if (mobileNavPanel.classList.contains('translate-x-full')) {
                    mobileMenu.classList.add('hidden');
                }
            }, 300);

            updateMobileToggleIcon(false);

            if (searchOverlay?.classList.contains('hidden') !== false) {
                document.body.classList.remove('overflow-hidden');
            }
        };

        const escapeHtml = (value = '') => value
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const renderResults = (query = '') => {
            if (!searchEnabled || !searchResults || !searchStatus) {
                return;
            }

            const trimmed = query.trim();

            if (trimmed.length < 2) {
                searchStatus.textContent = 'Type at least 2 letters to search.';
                searchResults.innerHTML = '';
                return;
            }

            const normalized = trimmed.toLowerCase();
            const allItems = /** @type {unknown[]} */ (JSON.parse(searchIndexJson));
            const matches = allItems
                .filter((item = null) => {
                    if (!item || typeof item !== 'object') {
                        return false;
                    }

                    const entry = /** @type {{title?: string; description?: string; section?: string; url?: string; type?: string}} */ (item);
                    const content = `${entry.title || ''} ${entry.description || ''} ${entry.section || ''} ${entry.url || ''}`.toLowerCase();

                    return content.includes(normalized);
                })
                .slice(0, 20);

            searchStatus.textContent = `${matches.length} result${matches.length === 1 ? '' : 's'} found.`;

            if (matches.length === 0) {
                searchResults.innerHTML = '<p class="rounded-2xl border border-white/15 bg-white/5 p-4 text-sm text-slate-300">No matching content found.</p>';
                return;
            }

            searchResults.innerHTML = matches
                .map((item = null) => `
                    <a href="${escapeHtml((/** @type {{url?: string}} */ (item)).url || '#')}" class="mb-3 block rounded-2xl border border-white/15 bg-white/5 p-4 transition hover:border-sky-300/60 hover:bg-white/10">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">${escapeHtml((/** @type {{section?: string; type?: string}} */ (item)).section || (/** @type {{section?: string; type?: string}} */ (item)).type || '')}</p>
                        <p class="mt-2 text-lg font-bold tracking-tight text-white">${escapeHtml((/** @type {{title?: string}} */ (item)).title || '')}</p>
                        <p class="mt-2 text-sm leading-6 text-slate-300">${escapeHtml((/** @type {{description?: string}} */ (item)).description || 'Open this result to view details.')}</p>
                        <p class="mt-3 text-xs text-slate-400">${escapeHtml((/** @type {{url?: string}} */ (item)).url || '')}</p>
                    </a>
                `)
                .join('');
        };

        const loadSearchIndex = async () => {
            if (!searchEnabled || searchLoaded) {
                return;
            }

            try {
                const response = await fetch('/search-index.json');

                if (!response.ok) {
                    throw new Error('Failed to load search index');
                }

                searchIndexJson = await response.text();
                searchLoaded = true;
            } catch {
                if (searchStatus) {
                    searchStatus.textContent = 'Search is unavailable right now.';
                }
            }
        };

        const openSearch = async () => {
            if (!searchEnabled || !searchOverlay) {
                return;
            }

            closeMobileMenu();
            searchOverlay.classList.remove('hidden');
            searchOverlay.style.display = 'block';
            searchOverlay.setAttribute('aria-hidden', 'false');
            document.body.classList.add('overflow-hidden');

            await loadSearchIndex();

            setTimeout(() => {
                searchInput?.focus();
            }, 30);
        };

        const closeSearch = () => {
            if (!searchEnabled || !searchOverlay) {
                return;
            }

            searchOverlay.classList.add('hidden');
            searchOverlay.style.display = 'none';
            searchOverlay.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('overflow-hidden');
        };

        toggleButton?.addEventListener('click', () => {
            const isOpen = toggleButton.getAttribute('aria-expanded') === 'true';

            if (isOpen) {
                closeMobileMenu();
            } else {
                openMobileMenu();
            }
        });

        mobileNavBackdrop?.addEventListener('click', closeMobileMenu);

        mobileLinks?.forEach((link) => {
            link.addEventListener('click', closeMobileMenu);
        });

        mobileMenuCloseButtons.forEach((button) => {
            button.addEventListener('click', closeMobileMenu);
        });

        if (searchEnabled) {
            searchOpenButtons.forEach((button) => {
                button.addEventListener('click', openSearch);
            });

            searchCloseButtons.forEach((button) => {
                button.addEventListener('click', closeSearch);
            });

            // Delegated fallback so search still works even if nav markup changes.
            document.addEventListener('click', (event) => {
                const target = event.target;

                if (!(target instanceof Element)) {
                    return;
                }

                if (target.closest('[data-search-open]')) {
                    event.preventDefault();
                    openSearch();
                    return;
                }

                if (target.closest('[data-search-close]')) {
                    event.preventDefault();
                    closeSearch();
                }
            });

            searchOverlay?.addEventListener('click', (event) => {
                if (event.target === searchOverlay) {
                    closeSearch();
                }
            });

            searchInput?.addEventListener('input', (event) => {
                const target = event.target;
                const query = target instanceof HTMLInputElement ? target.value : '';

                renderResults(query);
            });

            document.addEventListener('keydown', (event) => {
                const hasMetaKey = event.metaKey || event.ctrlKey;

                if (event.key === 'Escape') {
                    closeSearch();
                    closeMobileMenu();
                }

                if (hasMetaKey && event.key.toLowerCase() === 'k') {
                    event.preventDefault();
                    openSearch();
                }
            });
        }

        window.addEventListener('resize', () => {
            if (mobileMenu instanceof HTMLElement) {
                mobileMenu.style.top = `${getMobileMenuTopOffset()}px`;
            }

            if (window.innerWidth >= 768) {
                closeMobileMenu();
            }
        });
    </script>
</body>
</html>