        :global(.primary-desktop-nav .nav-menu-item) {
            position: relative;
            list-style: none;
        }

        :global(.primary-desktop-nav .nav-menu-item::after) {
            content: '';
            position: absolute;
            left: 0;
            top: 100%;
            width: 100%;
            height: 0.55rem;
        }

        :global(.primary-desktop-nav .nav-submenu) {
            display: none;
            min-width: 18rem;
            position: absolute;
            z-index: 70;
            border: 1px solid rgb(226 232 240);
            border-radius: 1rem;
            background: rgb(255 255 255);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.15);
            padding: 0.4rem;
        }

        :global(html.dark .primary-desktop-nav .nav-submenu) {
            border-color: rgb(51 65 85);
            background: rgb(15 23 42);
            box-shadow: 0 14px 36px rgba(2, 6, 23, 0.6);
        }

        :global(.primary-desktop-nav .nav-submenu-root) {
            left: 0;
            top: calc(100% + 0.35rem);
        }

        :global(.primary-desktop-nav .nav-submenu-root.nav-submenu-left) {
            left: auto;
            right: 0;
        }

        :global(.primary-desktop-nav .nav-submenu-flyout) {
            left: calc(100% + 0.35rem);
            top: 0;
        }

        :global(.primary-desktop-nav .nav-submenu-flyout.nav-submenu-left) {
            left: auto;
            right: calc(100% + 0.35rem);
        }

        :global(.primary-desktop-nav .nav-submenu-flyout::before) {
            content: '';
            position: absolute;
            left: -0.55rem;
            top: 0;
            width: 0.55rem;
            height: 100%;
        }

        :global(.primary-desktop-nav .nav-menu-item:hover > .nav-submenu),
        :global(.primary-desktop-nav .nav-menu-item:focus-within > .nav-submenu) {
            display: block;
        }
    </style>

    <script>
        // @ts-nocheck
        const toggleButton = document.getElementById('mobile-nav-toggle');
        const headerElement = document.querySelector('header');
        const mobileMenu = document.getElementById('mobile-nav-menu');
        const mobileNavBackdrop = document.getElementById('mobile-nav-backdrop');
        const mobileNavPanel = document.getElementById('mobile-nav-panel');
        const mobileMenuCloseButtons = document.querySelectorAll('[data-mobile-nav-close]');
        const openIcon = document.getElementById('mobile-nav-open-icon');
        const closeIcon = document.getElementById('mobile-nav-close-icon');
        const mobileLinks = mobileMenu?.querySelectorAll('a');
        const searchEnabled = document.body.dataset.searchEnabled === 'true';
        const themeToggles = document.querySelectorAll('[data-theme-toggle]');
        const rootElement = document.documentElement;
        const themeMetaTag = document.querySelector('meta[name="theme-color"]');
        const lightThemeColor = '#0f172a';
        const darkThemeColor = '#020617';
        const defaultTheme = document.body.dataset.themeDefault || 'system';
        const parsedThemeModes = (() => {
            try {
                const parsed = JSON.parse(document.body.dataset.themeModes || '[]');

                if (!Array.isArray(parsed)) {
                    return [];
                }

                return parsed.filter((value) => value === 'light' || value === 'dark' || value === 'system');
            } catch {
                return [];
            }
        })();
        const themeModes = parsedThemeModes.length > 0 ? parsedThemeModes : ['light', 'dark', 'system'];
        const searchOverlay = searchEnabled ? document.getElementById('search-overlay') : null;
        const searchOpenButtons = searchEnabled ? document.querySelectorAll('[data-search-open]') : [];
        const searchCloseButtons = searchEnabled ? document.querySelectorAll('[data-search-close]') : [];
        const searchInput = searchEnabled ? document.getElementById('site-search-input') : null;
        const searchStatus = searchEnabled ? document.getElementById('site-search-status') : null;
        const searchResults = searchEnabled ? document.getElementById('site-search-results') : null;
        const backToTopButton = document.getElementById('back-to-top-button');
        const desktopNav = document.querySelector('.primary-desktop-nav');

        let searchIndexJson = '[]';
        let searchLoaded = false;
        const storageKey = 'site-theme';

        const getSystemTheme = () => window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

        const getThemePreference = () => {
            const savedPreference = rootElement.dataset.themePreference;

            if ((savedPreference === 'light' || savedPreference === 'dark' || savedPreference === 'system') && themeModes.includes(savedPreference)) {
                return savedPreference;
            }

            return themeModes.includes(defaultTheme) ? defaultTheme : themeModes[0];
        };

        const resolveTheme = (preference = 'system') => preference === 'system' ? getSystemTheme() : preference;

        const updateThemeButtons = (resolvedTheme = 'light', preference = 'system') => {
            themeToggles.forEach((button) => {
                const sunIcon = button.querySelector('[data-theme-icon="sun"]');
                const moonIcon = button.querySelector('[data-theme-icon="moon"]');
                const systemIcon = button.querySelector('[data-theme-icon="system"]');
                const isSystem = preference === 'system';
                const isDark = preference === 'dark';
                const isLight = preference === 'light';

                sunIcon?.classList.toggle('hidden', !isLight);
                moonIcon?.classList.toggle('hidden', !isDark);
                systemIcon?.classList.toggle('hidden', !isSystem);

                const modeText = isSystem
                    ? `Device automatic (${resolvedTheme})`
                    : isDark
                        ? 'Dark'
                        : 'Light';

                button.setAttribute('aria-label', `Theme mode: ${modeText}`);
                button.setAttribute('title', `Theme mode: ${modeText}`);
            });
        };

        const applyTheme = (preference = 'system') => {
            const resolvedTheme = resolveTheme(preference);
            const isDark = resolvedTheme === 'dark';

            rootElement.classList.toggle('dark', isDark);
            rootElement.dataset.theme = resolvedTheme;
            rootElement.dataset.themePreference = preference;

            if (themeMetaTag instanceof HTMLMetaElement) {
                themeMetaTag.content = isDark ? darkThemeColor : lightThemeColor;
            }

            updateThemeButtons(resolvedTheme, preference);
        };

        const cycleTheme = () => {
            const currentPreference = getThemePreference();
            const currentIndex = themeModes.indexOf(currentPreference);
            const nextIndex = currentIndex === -1
                ? 0
                : (currentIndex + 1) % themeModes.length;
            const nextPreference = themeModes[nextIndex];

            applyTheme(nextPreference);

            try {
                localStorage.setItem(storageKey, nextPreference);
            } catch {
                // Ignore storage errors in private/incognito contexts.
            }
        };

        const updateMobileToggleIcon = (isOpen = false) => {
            openIcon?.classList.toggle('hidden', isOpen);
            closeIcon?.classList.toggle('hidden', !isOpen);
            toggleButton?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        };

        const updateBackToTopVisibility = () => {
            if (!(backToTopButton instanceof HTMLAnchorElement)) {
                return;
            }

            const shouldShow = window.scrollY > 120;

            backToTopButton.classList.toggle('opacity-0', !shouldShow);
            backToTopButton.classList.toggle('pointer-events-none', !shouldShow);
            backToTopButton.classList.toggle('translate-y-2', !shouldShow);
            backToTopButton.classList.toggle('opacity-100', shouldShow);
            backToTopButton.classList.toggle('translate-y-0', shouldShow);
            backToTopButton.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
            backToTopButton.tabIndex = shouldShow ? 0 : -1;
        };

        const getMobileMenuTopOffset = () => {
            if (!(headerElement instanceof HTMLElement)) {
                return 76;
            }

            const headerRect = headerElement.getBoundingClientRect();

            // When top bar is visible, header can be lower than viewport top.
            // Drawer should start below the currently visible header block.
            return Math.max(0, Math.round(headerRect.bottom));
        };

        const openMobileMenu = () => {
            if (!mobileMenu || !mobileNavPanel) {
                return;
            }

            mobileMenu.style.top = `${getMobileMenuTopOffset()}px`;

            mobileMenu.classList.remove('hidden');
            mobileMenu.setAttribute('aria-hidden', 'false');

            requestAnimationFrame(() => {
                mobileNavPanel.classList.remove('translate-x-full');
            });

            updateMobileToggleIcon(true);
            document.body.classList.add('overflow-hidden');
        };

        try {
            const storedTheme = localStorage.getItem(storageKey);

            if ((storedTheme === 'light' || storedTheme === 'dark' || storedTheme === 'system') && themeModes.includes(storedTheme)) {
                applyTheme(storedTheme);
            } else {
                applyTheme(getThemePreference());
            }
        } catch {
            applyTheme(getThemePreference());
        }

        const colorSchemeQuery = window.matchMedia('(prefers-color-scheme: dark)');
        colorSchemeQuery.addEventListener('change', () => {
            if (getThemePreference() === 'system') {
                applyTheme('system');
            }
        });

        themeToggles.forEach((button) => {
            button.addEventListener('click', cycleTheme);
        });

        const measureSubmenuRect = (submenu) => {
            const prevDisplay = submenu.style.display;
            const prevVisibility = submenu.style.visibility;
            const prevPointerEvents = submenu.style.pointerEvents;

            submenu.style.display = 'block';
            submenu.style.visibility = 'hidden';
            submenu.style.pointerEvents = 'none';

            const rect = submenu.getBoundingClientRect();

            submenu.style.display = prevDisplay;
            submenu.style.visibility = prevVisibility;
            submenu.style.pointerEvents = prevPointerEvents;

            return rect;
        };

        const placeSubmenuHorizontally = (menuItem) => {
            if (!(menuItem instanceof HTMLElement)) {
                return;
            }

            const submenu = menuItem.querySelector(':scope > .nav-submenu');

            if (!(submenu instanceof HTMLElement)) {
                return;
            }

            submenu.classList.remove('nav-submenu-left');
            submenu.style.transform = '';

            const parentRect = menuItem.getBoundingClientRect();
            const submenuRect = measureSubmenuRect(submenu);
            const isRoot = submenu.classList.contains('nav-submenu-root');
            const gap = 6;
            const viewportPadding = 8;
            const maxViewportWidth = Math.max(220, window.innerWidth - (viewportPadding * 2));

            const spaceRight = isRoot
                ? window.innerWidth - parentRect.left - viewportPadding
                : window.innerWidth - parentRect.right - gap - viewportPadding;
            const spaceLeft = isRoot
                ? parentRect.right - viewportPadding
                : parentRect.left - gap - viewportPadding;

            // Flip to left whenever right side is insufficient.
            if (submenuRect.width > spaceRight) {
                submenu.classList.add('nav-submenu-left');
            }

            // If left is even tighter than right, keep it on right.
            if (submenuRect.width > spaceLeft && spaceLeft < spaceRight) {
                submenu.classList.remove('nav-submenu-left');
            }

            submenu.style.maxWidth = `${maxViewportWidth}px`;

            // Final viewport clamp for both first-level and nested submenus.
            const placedRect = measureSubmenuRect(submenu);
            let shiftX = 0;

            if (placedRect.right > window.innerWidth - viewportPadding) {
                shiftX = (window.innerWidth - viewportPadding) - placedRect.right;
            }

            const leftAfterShift = placedRect.left + shiftX;

            if (leftAfterShift < viewportPadding) {
                shiftX += viewportPadding - leftAfterShift;
            }

            if (shiftX !== 0) {
                submenu.style.transform = `translateX(${shiftX}px)`;
            }
        };

        const setupDesktopSubmenuPlacement = () => {
            if (!(desktopNav instanceof HTMLElement)) {
                return;
            }

            const menuItems = desktopNav.querySelectorAll('.nav-menu-item');

            menuItems.forEach((item) => {
                item.addEventListener('mouseenter', () => placeSubmenuHorizontally(item));
                item.addEventListener('focusin', () => placeSubmenuHorizontally(item));
            });

            const repositionVisibleMenus = () => {
                if (window.innerWidth < 768) {
                    return;
                }

                const visibleParents = desktopNav.querySelectorAll('.nav-menu-item:hover, .nav-menu-item:focus-within');
                visibleParents.forEach((item) => placeSubmenuHorizontally(item));
            };

            window.addEventListener('resize', repositionVisibleMenus);
            window.addEventListener('scroll', repositionVisibleMenus, { passive: true });
        };

        setupDesktopSubmenuPlacement();

        const closeMobileMenu = () => {
            if (!mobileMenu || !mobileNavPanel) {
                return;
            }

            mobileNavPanel.classList.add('translate-x-full');
            mobileMenu.setAttribute('aria-hidden', 'true');

            setTimeout(() => {
                if (mobileNavPanel.classList.contains('translate-x-full')) {
                    mobileMenu.classList.add('hidden');
                }
            }, 300);

            updateMobileToggleIcon(false);

            if (searchOverlay?.classList.contains('hidden') !== false) {
                document.body.classList.remove('overflow-hidden');
            }
        };

        const escapeHtml = (value = '') => value
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const renderResults = (query = '') => {
            if (!searchEnabled || !searchResults || !searchStatus) {
                return;
            }

            const trimmed = query.trim();

            if (trimmed.length < 2) {
                searchStatus.textContent = 'Type at least 2 letters to search.';
                searchResults.innerHTML = '';
                return;
            }

            const normalized = trimmed.toLowerCase();
            const allItems = /** @type {unknown[]} */ (JSON.parse(searchIndexJson));
            const matches = allItems
                .filter((item = null) => {
                    if (!item || typeof item !== 'object') {
                        return false;
                    }

                    const entry = /** @type {{title?: string; description?: string; section?: string; url?: string; type?: string}} */ (item);
                    const content = `${entry.title || ''} ${entry.description || ''} ${entry.section || ''} ${entry.url || ''}`.toLowerCase();

                    return content.includes(normalized);
                })
                .slice(0, 20);

            searchStatus.textContent = `${matches.length} result${matches.length === 1 ? '' : 's'} found.`;

            if (matches.length === 0) {
                searchResults.innerHTML = '<p class="rounded-2xl border border-white/15 bg-white/5 p-4 text-sm text-slate-300">No matching content found.</p>';
                return;
            }

            searchResults.innerHTML = matches
                .map((item = null) => `
                    <a href="${escapeHtml((/** @type {{url?: string}} */ (item)).url || '#')}" class="mb-3 block rounded-2xl border border-white/15 bg-white/5 p-4 transition hover:border-sky-300/60 hover:bg-white/10">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">${escapeHtml((/** @type {{section?: string; type?: string}} */ (item)).section || (/** @type {{section?: string; type?: string}} */ (item)).type || '')}</p>
                        <p class="mt-2 text-lg font-bold tracking-tight text-white">${escapeHtml((/** @type {{title?: string}} */ (item)).title || '')}</p>
                        <p class="mt-2 text-sm leading-6 text-slate-300">${escapeHtml((/** @type {{description?: string}} */ (item)).description || 'Open this result to view details.')}</p>
                        <p class="mt-3 text-xs text-slate-400">${escapeHtml((/** @type {{url?: string}} */ (item)).url || '')}</p>
                    </a>
                `)
                .join('');
        };

        const loadSearchIndex = async () => {
            if (!searchEnabled || searchLoaded) {
                return;
            }

            try {
                const response = await fetch('/search-index.json');

                if (!response.ok) {
                    throw new Error('Failed to load search index');
                }

                searchIndexJson = await response.text();
                searchLoaded = true;
            } catch {
                if (searchStatus) {
                    searchStatus.textContent = 'Search is unavailable right now.';
                }
            }
        };

        const openSearch = async () => {
            if (!searchEnabled || !searchOverlay) {
                return;
            }

            closeMobileMenu();
            searchOverlay.classList.remove('hidden');
            searchOverlay.style.display = 'block';
            searchOverlay.setAttribute('aria-hidden', 'false');
            document.body.classList.add('overflow-hidden');

            await loadSearchIndex();

            setTimeout(() => {
                searchInput?.focus();
            }, 30);
        };

        const closeSearch = () => {
            if (!searchEnabled || !searchOverlay) {
                return;
            }

            searchOverlay.classList.add('hidden');
            searchOverlay.style.display = 'none';
            searchOverlay.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('overflow-hidden');
        };

        toggleButton?.addEventListener('click', () => {
            const isOpen = toggleButton.getAttribute('aria-expanded') === 'true';

            if (isOpen) {
                closeMobileMenu();
            } else {
                openMobileMenu();
            }
        });

        mobileNavBackdrop?.addEventListener('click', closeMobileMenu);

        mobileLinks?.forEach((link) => {
            link.addEventListener('click', closeMobileMenu);
        });

        mobileMenuCloseButtons.forEach((button) => {
            button.addEventListener('click', closeMobileMenu);
        });

        if (searchEnabled) {
            searchOpenButtons.forEach((button) => {
                button.addEventListener('click', openSearch);
            });

            searchCloseButtons.forEach((button) => {
                button.addEventListener('click', closeSearch);
            });

            // Delegated fallback so search still works even if nav markup changes.
            document.addEventListener('click', (event) => {
                const target = event.target;

                if (!(target instanceof Element)) {
                    return;
                }

                if (target.closest('[data-search-open]')) {
                    event.preventDefault();
                    openSearch();
                    return;
                }

                if (target.closest('[data-search-close]')) {
                    event.preventDefault();
                    closeSearch();
                }
            });

            searchOverlay?.addEventListener('click', (event) => {
                if (event.target === searchOverlay) {
                    closeSearch();
                }
            });

            searchInput?.addEventListener('input', (event) => {
                const target = event.target;
                const query = target instanceof HTMLInputElement ? target.value : '';

                renderResults(query);
            });

            document.addEventListener('keydown', (event) => {
                const hasMetaKey = event.metaKey || event.ctrlKey;

                if (event.key === 'Escape') {
                    closeSearch();
                    closeMobileMenu();
                }

                if (hasMetaKey && event.key.toLowerCase() === 'k') {
                    event.preventDefault();
                    openSearch();
                }
            });
        }

        window.addEventListener('resize', () => {
            if (mobileMenu instanceof HTMLElement) {
                mobileMenu.style.top = `${getMobileMenuTopOffset()}px`;
            }

            if (window.innerWidth >= 768) {
                closeMobileMenu();
            }
        });

        updateBackToTopVisibility();
        window.addEventListener('scroll', updateBackToTopVisibility, { passive: true });
    </script>
    {bodyEndTrackingTags.map((tag) => <Fragment set:html={tag.html} />)}
</body>
</html>