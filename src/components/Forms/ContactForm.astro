---
import { siteConfig } from '../../config/site';

const {
  title = 'Contact Us',
  description = 'Submit your query and our team will respond as soon as possible.',
  source = 'website',
  submitLabel = 'Send Message',
  className = '',
  showSubject = false,
  endpoint = siteConfig.forms.contact.endpoint,
  method = siteConfig.forms.contact.method,
  successMessage = siteConfig.forms.contact.successMessage,
  errorMessage = siteConfig.forms.contact.errorMessage,
  serverUnavailableMessage = siteConfig.forms.contact.serverUnavailableMessage,
} = Astro.props as {
  title?: string;
  description?: string;
  source?: string;
  submitLabel?: string;
  className?: string;
  showSubject?: boolean;
  endpoint?: string;
  method?: 'POST' | 'PUT';
  successMessage?: string;
  errorMessage?: string;
  serverUnavailableMessage?: string;
};

const resolvedEndpoint = endpoint?.trim() || '';
const resolvedMethod = method || 'POST';
const isEnabled = siteConfig.forms.contact.enabled && resolvedEndpoint.length > 0;
---

<section class:list={[
  'rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-8',
  className,
]}>
  <div class="mb-6 space-y-2">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{title}</h2>
    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">{description}</p>
  </div>

  {!isEnabled ? (
    <p class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900 dark:border-amber-800 dark:bg-amber-900/20 dark:text-amber-200">
      Contact form endpoint is not configured. Set PUBLIC_CONTACT_FORM_ENDPOINT to enable submissions.
    </p>
  ) : (
    <form class="space-y-4" data-contact-form data-endpoint={resolvedEndpoint} data-method={resolvedMethod} data-source={source}>
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="space-y-2 text-sm font-medium text-slate-700 dark:text-slate-200">
          <span>Full Name</span>
          <input name="name" required aria-describedby="contact-form-name-error" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-600 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-900" />
          <span id="contact-form-name-error" class="hidden text-sm text-rose-600 dark:text-rose-300" data-field-error="name"></span>
        </label>

        <label class="space-y-2 text-sm font-medium text-slate-700 dark:text-slate-200">
          <span>Phone Number</span>
          <input name="contact_number" required inputmode="tel" aria-describedby="contact-form-contact-number-error" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-600 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-900" />
          <span id="contact-form-contact-number-error" class="hidden text-sm text-rose-600 dark:text-rose-300" data-field-error="contact_number"></span>
        </label>
      </div>

      <label class="space-y-2 text-sm font-medium text-slate-700 dark:text-slate-200">
        <span>Email Address</span>
        <input name="email" type="email" required aria-describedby="contact-form-email-error" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-600 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-900" />
        <span id="contact-form-email-error" class="hidden text-sm text-rose-600 dark:text-rose-300" data-field-error="email"></span>
      </label>

      {showSubject && (
        <label class="space-y-2 text-sm font-medium text-slate-700 dark:text-slate-200">
          <span>Subject</span>
          <input name="subject" aria-describedby="contact-form-subject-error" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-600 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-900" />
          <span id="contact-form-subject-error" class="hidden text-sm text-rose-600 dark:text-rose-300" data-field-error="subject"></span>
        </label>
      )}

      <label class="space-y-2 text-sm font-medium text-slate-700 dark:text-slate-200">
        <span>Message</span>
        <textarea name="message" required rows="5" aria-describedby="contact-form-message-error" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-600 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-900"></textarea>
        <span id="contact-form-message-error" class="hidden text-sm text-rose-600 dark:text-rose-300" data-field-error="message"></span>
      </label>

      <div class="flex flex-wrap items-center gap-3">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-500 disabled:cursor-not-allowed disabled:opacity-60" data-submit-button>
          {submitLabel}
        </button>
        <p class="text-sm text-slate-600 dark:text-slate-300" data-form-status aria-live="polite"></p>
      </div>
    </form>
  )}
</section>

<script is:inline define:vars={{ successMessage, errorMessage, serverUnavailableMessage, showSubject }}>
  (() => {
    const FIELD_ERROR_SENTINEL = '__FIELD_ERRORS__';
    const forms = document.querySelectorAll('form[data-contact-form]');

    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      if (form.dataset.formBound === 'true') {
        return;
      }

      form.dataset.formBound = 'true';

      const statusElement = form.querySelector('[data-form-status]');
      const submitButton = form.querySelector('[data-submit-button]');
      const fieldErrorElements = new Map(
        Array.from(form.querySelectorAll('[data-field-error]')).map((element) => [
          element.getAttribute('data-field-error'),
          element,
        ]),
      );

      const fieldInputs = new Map(
        ['name', 'contact_number', 'email', 'subject', 'message'].map((fieldName) => [
          fieldName,
          form.elements.namedItem(fieldName),
        ]),
      );

      const clearFieldErrors = () => {
        fieldErrorElements.forEach((element) => {
          if (!(element instanceof HTMLElement)) {
            return;
          }

          element.textContent = '';
          element.classList.add('hidden');
        });

        fieldInputs.forEach((input) => {
          if (!(input instanceof HTMLElement)) {
            return;
          }

          input.removeAttribute('aria-invalid');
          input.classList.remove('border-rose-500', 'focus:border-rose-500', 'focus:ring-rose-200', 'dark:border-rose-400', 'dark:focus:ring-rose-900/60');
        });
      };

      const setFieldErrors = (errors) => {
        clearFieldErrors();

        if (!errors || typeof errors !== 'object') {
          return;
        }

        Object.entries(errors).forEach(([fieldName, messages]) => {
          const firstMessage = Array.isArray(messages) ? messages.find((message) => typeof message === 'string' && message.trim().length > 0) : null;
          const errorElement = fieldErrorElements.get(fieldName);
          const input = fieldInputs.get(fieldName);

          if (firstMessage && errorElement instanceof HTMLElement) {
            errorElement.textContent = firstMessage;
            errorElement.classList.remove('hidden');
          }

          if (firstMessage && input instanceof HTMLElement) {
            input.setAttribute('aria-invalid', 'true');
            input.classList.add('border-rose-500', 'focus:border-rose-500', 'focus:ring-rose-200', 'dark:border-rose-400', 'dark:focus:ring-rose-900/60');
          }
        });
      };

      const setStatus = (message, type) => {
        if (!(statusElement instanceof HTMLElement)) {
          return;
        }

        statusElement.textContent = message;
        statusElement.classList.remove('text-emerald-600', 'text-rose-600', 'dark:text-emerald-300', 'dark:text-rose-300');

        if (type === 'success') {
          statusElement.classList.add('text-emerald-600', 'dark:text-emerald-300');
        }

        if (type === 'error') {
          statusElement.classList.add('text-rose-600', 'dark:text-rose-300');
        }
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        clearFieldErrors();
        setStatus('', 'idle');

        const endpoint = form.dataset.endpoint || '';
        const method = form.dataset.method || 'POST';
        const source = form.dataset.source || 'website';

        if (!endpoint) {
          setStatus(errorMessage, 'error');
          return;
        }

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
        }

        setStatus('Submitting...', 'idle');

        try {
          const formData = new FormData(form);

        // Honeypot spam guard
          if ((formData.get('website') || '').toString().trim().length > 0) {
            setStatus(successMessage, 'success');
            form.reset();
            return;
          }

          const payload = {
            source,
            page_path: window.location.pathname,
            submitted_at: new Date().toISOString(),
            name: (formData.get('name') || '').toString().trim(),
            contact_number: (formData.get('contact_number') || '').toString().trim(),
            email: (formData.get('email') || '').toString().trim(),
            message: (formData.get('message') || '').toString().trim(),
          };

          if (showSubject) {
            payload.subject = (formData.get('subject') || '').toString().trim();
          }

          const response = await fetch(endpoint, {
            method,
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            let apiErrorMessage = '';
            let fieldErrors = null;

            try {
              const apiResponse = await response.json();
              fieldErrors = apiResponse?.errors;

              if (fieldErrors && typeof fieldErrors === 'object') {
                setFieldErrors(fieldErrors);
                throw new Error(FIELD_ERROR_SENTINEL);
              }

              if (typeof apiResponse?.message === 'string') {
                apiErrorMessage = apiResponse.message.trim();
              }
            } catch (error) {
              if (error instanceof Error && error.message === FIELD_ERROR_SENTINEL) {
                throw error;
              }

              apiErrorMessage = '';
            }

            if (!apiErrorMessage) {
              if (response.status === 422) {
                apiErrorMessage = 'Please review the highlighted fields.';
              } else if (response.status === 429) {
                apiErrorMessage = 'Too many requests. Please try again after some time.';
              } else if (response.status >= 500) {
                apiErrorMessage = serverUnavailableMessage;
              } else {
                apiErrorMessage = `Request failed (HTTP ${response.status}).`;
              }
            }

            throw new Error(apiErrorMessage);
          }

          form.reset();
          clearFieldErrors();
          setStatus(successMessage, 'success');
        } catch (error) {
          if (error instanceof Error && error.message === FIELD_ERROR_SENTINEL) {
            setStatus('', 'idle');
          } else if (error instanceof TypeError) {
            setStatus(serverUnavailableMessage, 'error');
          } else {
            const message = error instanceof Error && error.message ? error.message : errorMessage;
            setStatus(message, 'error');
          }
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
          }
        }
      });
    });
  })();
</script>
