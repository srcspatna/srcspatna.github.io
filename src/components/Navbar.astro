  <!-- Mobile Menu Content -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-200 animate-in fade-in slide-in-from-top-4 duration-200">
    <div class="space-y-1 px-4 pb-3 pt-2">
