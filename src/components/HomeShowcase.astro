---
type SlideAccent = 'amber' | 'emerald' | 'blue';

type ShowcaseSlide = {
	eyebrow: string;
	title: string;
	description: string;
	ctaLabel: string;
	ctaHref: string;
	secondaryLabel: string;
	secondaryHref: string;
	statLabel: string;
	statValue: string;
	accent: SlideAccent;
};

type ActivitySlide = {
	imageSrc: string;
	imageAlt: string;
	title: string;
	description: string;
	href: string;
};

type FeaturedItem = {
	href: string;
	title: string;
	description: string;
	tag: string;
	dateLabel?: string;
};

const {
	activitySlides = [],
	featuredItems = [],
	marqueeItems = [],
	slides = [],
} = Astro.props as {
	activitySlides?: ActivitySlide[];
	featuredItems?: FeaturedItem[];
	marqueeItems?: string[];
	slides?: ShowcaseSlide[];
};

const marqueeLoop = marqueeItems.length > 0 ? [...marqueeItems, ...marqueeItems] : [];

const accentClasses: Record<SlideAccent, { shell: string; pill: string; line: string; glow: string }> = {
	amber: {
		shell: 'from-amber-200 via-orange-100 to-white dark:from-slate-900 dark:via-amber-950 dark:to-orange-900',
		pill: 'bg-amber-500/15 text-amber-700 ring-amber-400/30 dark:bg-amber-400/15 dark:text-amber-200',
		line: 'from-amber-500 to-orange-500',
		glow: 'bg-amber-400/30 dark:bg-amber-500/20',
	},
	emerald: {
		shell: 'from-emerald-200 via-teal-100 to-white dark:from-slate-900 dark:via-emerald-950 dark:to-teal-900',
		pill: 'bg-emerald-500/15 text-emerald-700 ring-emerald-400/30 dark:bg-emerald-400/15 dark:text-emerald-200',
		line: 'from-emerald-500 to-teal-500',
		glow: 'bg-emerald-400/30 dark:bg-emerald-500/20',
	},
	blue: {
		shell: 'from-sky-200 via-blue-100 to-white dark:from-slate-900 dark:via-blue-950 dark:to-sky-900',
		pill: 'bg-sky-500/15 text-sky-700 ring-sky-400/30 dark:bg-sky-400/15 dark:text-sky-200',
		line: 'from-sky-500 to-blue-500',
		glow: 'bg-sky-400/30 dark:bg-sky-500/20',
	},
};
---

<div data-home-showcase class="space-y-4">
	{marqueeLoop.length > 0 && (
		<div class="overflow-hidden rounded-full border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
			<div class="home-marquee-track flex min-w-max items-center gap-8 px-4 py-3 text-sm font-semibold text-slate-700 dark:text-slate-200">
				{marqueeLoop.map((item, index) => (
					<div class="inline-flex items-center gap-3 whitespace-nowrap" aria-hidden={index >= marqueeItems.length ? 'true' : 'false'}>
						<span class="inline-flex h-2.5 w-2.5 rounded-full bg-linear-to-r from-amber-500 to-orange-500"></span>
						<span>{item}</span>
					</div>
				))}
			</div>
		</div>
	)}

	{slides.length > 0 && (
		<section class="overflow-hidden rounded-4xl border border-slate-200 bg-white shadow-xl shadow-slate-900/5 dark:border-slate-700 dark:bg-slate-900 dark:shadow-slate-950/20">
			<div class="relative" data-home-slider>
				{slides.map((slide, index) => {
					const accent = accentClasses[slide.accent];

					return (
						<article
							class:list={[
								'home-slide relative grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.4fr)_minmax(260px,0.8fr)] lg:px-10 lg:py-10 dark:ring-1 dark:ring-white/10',
								`bg-linear-to-br ${accent.shell}`,
								index === 0 ? 'block' : 'hidden',
							]}
							data-slide-index={String(index)}
						>
							<div class={`absolute right-0 top-0 h-40 w-40 rounded-full blur-3xl ${accent.glow}`}></div>
							<div class="relative z-10 space-y-5">
								<span class:list={[
									'inline-flex rounded-full px-4 py-1 text-xs font-bold uppercase tracking-[0.28em] ring-1',
									accent.pill,
								]}>
									{slide.eyebrow}
								</span>
								<div class={`h-1 w-20 rounded-full bg-linear-to-r ${accent.line}`}></div>
								<h2 class="max-w-3xl text-3xl font-extrabold tracking-tight text-slate-950 dark:text-white sm:text-4xl">
									{slide.title}
								</h2>
								<p class="max-w-2xl text-base leading-8 text-slate-700 dark:text-slate-200 sm:text-lg">
									{slide.description}
								</p>
								<div class="flex flex-wrap gap-3">
									<a href={slide.ctaHref} class="inline-flex items-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
										{slide.ctaLabel}
									</a>
									<a href={slide.secondaryHref} class="inline-flex items-center rounded-full border border-slate-300 px-5 py-2.5 text-sm font-bold text-slate-800 transition hover:border-slate-950 hover:text-slate-950 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-300 dark:hover:text-white">
										{slide.secondaryLabel}
									</a>
								</div>
							</div>

							<div class="relative z-10 flex items-end">
								<div class="w-full rounded-[1.75rem] border border-white/50 bg-white/70 p-6 backdrop-blur dark:border-slate-700/80 dark:bg-slate-950/90 dark:shadow-2xl dark:shadow-slate-950/40">
									<p class="text-xs font-bold uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">{slide.statLabel}</p>
									<p class="mt-3 text-2xl font-extrabold tracking-tight text-slate-950 dark:text-white">{slide.statValue}</p>
									<p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-200">
										Organized access to school information helps families reach the right page quickly from the home screen.
									</p>
								</div>
							</div>
						</article>
					);
				})}

				<div class="flex items-center justify-between gap-4 border-t border-slate-200 px-6 py-4 dark:border-slate-700 dark:bg-slate-950/80 sm:px-8">
					<div class="flex items-center gap-2" aria-label="Slider navigation">
						{slides.map((slide, index) => (
							<button
								type="button"
								class:list={[
									'home-slide-dot h-2.5 rounded-full bg-slate-300 transition-all dark:bg-slate-700',
									index === 0 ? 'w-10' : 'w-2.5',
								]}
								data-slide-target={String(index)}
								aria-label={`Show slide ${index + 1}: ${slide.eyebrow}`}
							></button>
						))}
					</div>

					<div class="flex items-center gap-2">
						<button type="button" class="home-slide-prev inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-950 hover:text-slate-950 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-300 dark:hover:text-white">
							Previous
						</button>
						<button type="button" class="home-slide-next inline-flex items-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
							Next
						</button>
					</div>
				</div>
			</div>
		</section>
	)}

	{(activitySlides.length > 0 || featuredItems.length > 0) && (
		<section class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
			{activitySlides.length > 0 && (
				<section class="overflow-hidden rounded-4xl border border-slate-200 bg-white shadow-lg shadow-slate-900/5 dark:border-slate-700 dark:bg-slate-900 dark:shadow-slate-950/20" data-carousel data-interval="5200">
					<div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
						<p class="text-xs font-bold uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Children Activities</p>
						<h3 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-950 dark:text-white">Activity Image Slider</h3>
					</div>

					<div class="relative min-h-105">
						{activitySlides.map((slide, index) => (
							<article class:list={['carousel-slide absolute inset-0 flex flex-col', index === 0 ? 'block' : 'hidden']}>
								<a href={slide.href} class="group flex h-full flex-col">
									<div class="relative h-64 overflow-hidden bg-slate-100 dark:bg-slate-800">
										<img src={slide.imageSrc} alt={slide.imageAlt} class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]" loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
										<div class="absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-slate-950/70 to-transparent"></div>
									</div>
									<div class="flex flex-1 flex-col justify-between px-6 py-5">
										<div>
											<h4 class="text-xl font-extrabold tracking-tight text-slate-950 dark:text-white">{slide.title}</h4>
											<p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{slide.description}</p>
										</div>
										<span class="mt-5 inline-flex w-fit items-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition group-hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:group-hover:bg-slate-200">Open Activity Page</span>
									</div>
								</a>
							</article>
						))}
					</div>

					<div class="flex items-center justify-between gap-4 border-t border-slate-200 px-6 py-4 dark:border-slate-700">
						<div class="flex items-center gap-2">
							{activitySlides.map((slide, index) => (
								<button type="button" class:list={['carousel-dot h-2.5 rounded-full bg-slate-300 transition-all dark:bg-slate-700', index === 0 ? 'w-10' : 'w-2.5']} aria-label={`Show activity slide ${index + 1}: ${slide.title}`}></button>
							))}
						</div>
						<div class="flex items-center gap-2">
							<button type="button" class="carousel-prev inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-950 hover:text-slate-950 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-300 dark:hover:text-white">Previous</button>
							<button type="button" class="carousel-next inline-flex items-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">Next</button>
						</div>
					</div>
				</section>
			)}

			{featuredItems.length > 0 && (
				<section class="overflow-hidden rounded-4xl border border-slate-200 bg-white shadow-lg shadow-slate-900/5 dark:border-slate-700 dark:bg-slate-900 dark:shadow-slate-950/20" data-carousel data-interval="4300">
					<div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
						<p class="text-xs font-bold uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Featured Updates</p>
						<h3 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-950 dark:text-white">Featured Posts Slide Automatically</h3>
					</div>

					<div class="relative min-h-105 bg-linear-to-br from-slate-50 to-white dark:from-slate-900 dark:to-slate-950">
						{featuredItems.map((item, index) => (
							<article class:list={['carousel-slide absolute inset-0 px-6 py-6', index === 0 ? 'block' : 'hidden']}>
								<div class="flex h-full flex-col rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-950">
									<div class="flex items-center justify-between gap-3">
										<span class="inline-flex rounded-full bg-sky-500/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.24em] text-sky-700 dark:bg-sky-400/15 dark:text-sky-200">{item.tag}</span>
										{item.dateLabel && <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">{item.dateLabel}</span>}
									</div>
									<div class="mt-6 h-1 w-20 rounded-full bg-linear-to-r from-sky-500 to-blue-500"></div>
									<h4 class="mt-6 text-2xl font-extrabold tracking-tight text-slate-950 dark:text-white">{item.title}</h4>
									<p class="mt-4 flex-1 text-sm leading-8 text-slate-600 dark:text-slate-300">{item.description}</p>
									<a href={item.href} class="mt-6 inline-flex w-fit items-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">Read Featured Update</a>
								</div>
							</article>
						))}
					</div>

					<div class="flex items-center justify-between gap-4 border-t border-slate-200 px-6 py-4 dark:border-slate-700">
						<div class="flex items-center gap-2">
							{featuredItems.map((item, index) => (
								<button type="button" class:list={['carousel-dot h-2.5 rounded-full bg-slate-300 transition-all dark:bg-slate-700', index === 0 ? 'w-10' : 'w-2.5']} aria-label={`Show featured item ${index + 1}: ${item.title}`}></button>
							))}
						</div>
						<div class="flex items-center gap-2">
							<button type="button" class="carousel-prev inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-950 hover:text-slate-950 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-300 dark:hover:text-white">Previous</button>
							<button type="button" class="carousel-next inline-flex items-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">Next</button>
						</div>
					</div>
				</section>
			)}
		</section>
	)}
</div>

<style>
	.home-marquee-track {
		animation: home-marquee 24s linear infinite;
	}

	@keyframes home-marquee {
		from {
			transform: translateX(0);
		}

		to {
			transform: translateX(-50%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-marquee-track {
			animation: none;
		}
	}
</style>

<script>
	// @ts-nocheck
	const showcaseRoots = document.querySelectorAll('[data-home-showcase]');

	showcaseRoots.forEach((root) => {
		const carousels = root.querySelectorAll('[data-carousel]');

		carousels.forEach((carousel) => {
			if (!(carousel instanceof HTMLElement)) {
				return;
			}

			const slides = Array.from(carousel.querySelectorAll('.carousel-slide'));
			const dots = Array.from(carousel.querySelectorAll('.carousel-dot'));
			const prevButton = carousel.querySelector('.carousel-prev');
			const nextButton = carousel.querySelector('.carousel-next');
			const intervalMs = Number(carousel.dataset.interval || '5000');

			if (slides.length <= 1) {
				return;
			}

			let currentIndex = 0;
			let autoRotateId = 0;

			function applyCarouselState(nextIndex) {
				currentIndex = (nextIndex + slides.length) % slides.length;

				slides.forEach((slide, index) => {
					slide.classList.toggle('hidden', index !== currentIndex);
					slide.classList.toggle('block', index === currentIndex);
				});

				dots.forEach((dot, index) => {
					dot.classList.toggle('w-10', index === currentIndex);
					dot.classList.toggle('w-2.5', index !== currentIndex);
					dot.classList.toggle('bg-slate-900', index === currentIndex);
					dot.classList.toggle('dark:bg-white', index === currentIndex);
					dot.classList.toggle('bg-slate-300', index !== currentIndex);
					dot.classList.toggle('dark:bg-slate-700', index !== currentIndex);
				});
			}

			const startCarousel = () => {
				window.clearInterval(autoRotateId);
				autoRotateId = window.setInterval(() => {
					applyCarouselState(currentIndex + 1);
				}, intervalMs);
			};

			prevButton?.addEventListener('click', () => {
				applyCarouselState(currentIndex - 1);
				startCarousel();
			});

			nextButton?.addEventListener('click', () => {
				applyCarouselState(currentIndex + 1);
				startCarousel();
			});

			dots.forEach((dot, index) => {
				dot.addEventListener('click', () => {
					applyCarouselState(index);
					startCarousel();
				});
			});

			applyCarouselState(0);
			startCarousel();
		});

		const slider = root.querySelector('[data-home-slider]');

		if (!(slider instanceof HTMLElement)) {
			return;
		}

		const slides = Array.from(slider.querySelectorAll('.home-slide'));
		const dots = Array.from(slider.querySelectorAll('.home-slide-dot'));
		const prevButton = slider.querySelector('.home-slide-prev');
		const nextButton = slider.querySelector('.home-slide-next');

		if (slides.length <= 1) {
			return;
		}

		let currentIndex = 0;
		let autoRotateId = 0;

		function applyState(nextIndex) {
			currentIndex = (nextIndex + slides.length) % slides.length;

			slides.forEach((slide, index) => {
				slide.classList.toggle('hidden', index !== currentIndex);
				slide.classList.toggle('block', index === currentIndex);
			});

			dots.forEach((dot, index) => {
				dot.classList.toggle('w-10', index === currentIndex);
				dot.classList.toggle('w-2.5', index !== currentIndex);
				dot.classList.toggle('bg-slate-900', index === currentIndex);
				dot.classList.toggle('dark:bg-white', index === currentIndex);
				dot.classList.toggle('bg-slate-300', index !== currentIndex);
				dot.classList.toggle('dark:bg-slate-700', index !== currentIndex);
			});
		}

		const startAutoRotate = () => {
			window.clearInterval(autoRotateId);
			autoRotateId = window.setInterval(() => {
				applyState(currentIndex + 1);
			}, 6000);
		};

		prevButton?.addEventListener('click', () => {
			applyState(currentIndex - 1);
			startAutoRotate();
		});

		nextButton?.addEventListener('click', () => {
			applyState(currentIndex + 1);
			startAutoRotate();
		});

		dots.forEach((dot, index) => {
			dot.addEventListener('click', () => {
				applyState(index);
				startAutoRotate();
			});
		});

		applyState(0);
		startAutoRotate();
	});
</script>